        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num06"/>
        <ontologia:descripcion>Artículo divulgativo-satírico sobre la historia del preservativo, desde los egipcios y Gabriel Fallopio hasta el Doctor Condom (médico de Carlos II de Inglaterra). Explica su evolución de tripa de animal a látex vulcanizado. Incluye falsos anuncios de condones &quot;Descontrol&quot; (&quot;Virginidad es igual a cáncer&quot;) y viñetas humorísticas.</ontologia:descripcion>
        <ontologia:palabra_clave>Historia</ontologia:palabra_clave>
        <ontologia:palabra_clave>Humor verde</ontologia:palabra_clave>
        <ontologia:tipo_contenido>Texto</ontologia:tipo_contenido>
        <ontologia:titulo_contenido>Condón</ontologia:titulo_contenido>
        <rdfs:label>Contenido #0602</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0603 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0603">
