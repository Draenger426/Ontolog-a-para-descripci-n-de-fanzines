        <ontologia:tiene_autor rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#hugo"/>
        <ontologia:tiene_paginacion rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0502"/>
        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num05"/>
        <ontologia:descripcion>Test de personalidad satírico para evaluar el nivel de compromiso estudiantil. Las preguntas (I a X) plantean dilemas sobre la asistencia a clase, la toma de apuntes (&quot;fotocopiar los de los demás&quot;), el comportamiento en la cafetería (mencionando &quot;El Jardines&quot;) y la actitud ante los exámenes (copiar o soplar). Los resultados finales clasifican al lector en tres categorías: &quot;Espantoso empollón&quot; (Mayoría A, antisocial), &quot;Estudiante normal&quot; (Mayoría B) y &quot;Auténtico estudiante&quot; (Mayoría C, juerguista y con &quot;potra increíble&quot;).</ontologia:descripcion>
        <ontologia:palabra_clave>Test</ontologia:palabra_clave>
        <ontologia:tipo_contenido>Texto</ontologia:tipo_contenido>
        <ontologia:titulo_contenido>Test</ontologia:titulo_contenido>
        <rdfs:label>Contenido #0502</rdfs:label>
    </owl:NamedIndividual>
    


