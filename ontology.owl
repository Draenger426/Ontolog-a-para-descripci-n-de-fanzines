    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0405 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0405">
        <rdf:type rdf:resource="http://example.org/ontologia#Contenido"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0416"/>
        <ontologia:tiene_paginacion rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0405"/>
        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num04"/>
        <ontologia:descripcion>Anuncio satírico a página completa que promueve el uso de anticonceptivos durante las fiestas con el eslogan &quot;¡SEA NAVIDEÑO! USE PRESERVATIVOS EL POLVORÓN&quot;. La ilustración presenta a un Papá Noel risueño que sostiene una caja de estos profilácticos, descritos como &quot;LOS MÁS SOLICITADOS EN ESTAS FECHAS&quot;, jugando con el doble sentido entre el dulce típico navideño y la jerga sexual (&quot;echar un polvo&quot;).</ontologia:descripcion>
        <ontologia:palabra_clave>Humor verde</ontologia:palabra_clave>
        <ontologia:tipo_contenido>Publicidad</ontologia:tipo_contenido>
        <rdfs:label>Contenido #0405</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0406 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0406">
        <rdf:type rdf:resource="http://example.org/ontologia#Contenido"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0417"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0418"/>
