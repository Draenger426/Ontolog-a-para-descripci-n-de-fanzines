        <ontologia:tiene_paginacion rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag_seccion1002"/>
        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num10"/>
        <ontologia:descripcion>Dibujo de una pareja enamorada abrazándose. Esta portada da entrada a la sección de amor del número 10 de RAK.</ontologia:descripcion>
