<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#"
     xml:base="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:ontologia="http://example.org/ontologia#"
     xmlns:untitled-ontology-2="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2">
        <dc:creator>Hutman Ahmed Mohamed</dc:creator>
        <dc:creator>José Manuel Morales del Castillo</dc:creator>
        <dc:creator>Ángel Arcos Sánchez</dc:creator>
        <dc:description>Ontología para la descripción de fanzines. Se ha tomado como base el fanzine &quot;Radikal Al Kilo&quot;, que se publicó entre los años 80 y 90 del siglo XX en la Facultad de Ciencias de la Universidad de Granada.</dc:description>
        <dc:title>Ontología para descripción de fanzines</dc:title>
        <owl:ontologyIRI>http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2</owl:ontologyIRI>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/author -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/author"/>
    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/date -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/summary -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/summary"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#nota -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#nota"/>
    


    <!-- http://www.w3.org/2002/07/owl#ontologyIRI -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2002/07/owl#ontologyIRI"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#gYear -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#gYear"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/ontologia#aparece_en_imagen -->


    <owl:ObjectProperty rdf:about="http://example.org/ontologia#aparece_en_imagen">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#representa_contenido"/>
        <rdfs:domain rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Imagen"/>
        <rdfs:comment>Define el vínculo entre un contenido y el archivo de imagen en la que aparece digitalizado.</rdfs:comment>
        <rdfs:label>aparece en imagen</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontologia#incluye -->


    <owl:ObjectProperty rdf:about="http://example.org/ontologia#incluye">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en"/>
        <rdfs:domain rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:comment>Define el vínculo entre un número y un contenido específico que incluye.</rdfs:comment>
        <rdfs:label>incluye</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontologia#periodo_contiene_numero -->


    <owl:ObjectProperty rdf:about="http://example.org/ontologia#periodo_contiene_numero">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#numero_con_periodicidad"/>
        <rdfs:domain rdf:resource="http://example.org/ontologia#Periodicidad"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:comment>Define el vínculo entre una periodicidad y los números que se publicaron con esa frecuencia.</rdfs:comment>
        <rdfs:label>periodo contiene número</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontologia#tiene_autor -->


    <owl:ObjectProperty rdf:about="http://example.org/ontologia#tiene_autor">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_autor_de"/>
        <rdfs:domain rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Autor"/>
        <rdfs:comment>Define el vínculo de creación entre un contenido y su autor.</rdfs:comment>
        <rdfs:label>tiene autor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontologia#tiene_paginacion -->


    <owl:ObjectProperty rdf:about="http://example.org/ontologia#tiene_paginacion">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_paginacion_de"/>
        <rdfs:domain rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Paginacion"/>
        <rdfs:comment>Define cuál es la paginación de un contenido concreto.</rdfs:comment>
        <rdfs:label>tiene paginación</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontologia#tiene_periodicidad -->


    <owl:ObjectProperty rdf:about="http://example.org/ontologia#tiene_periodicidad">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_periodicidad_de"/>
        <rdfs:domain rdf:resource="http://example.org/ontologia#Revista"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Periodicidad"/>
        <rdfs:comment>Define la periodicidad de una revista.</rdfs:comment>
        <rdfs:label>tiene periodicidad</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontologia#viene_acompanado_de -->


    <owl:ObjectProperty rdf:about="http://example.org/ontologia#viene_acompanado_de">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#acompana_a"/>
        <rdfs:domain rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Suplemento"/>
        <rdfs:comment>Define el vínculo entre un número y su suplemento.</rdfs:comment>
        <rdfs:label>viene acompañado de</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#acompana_a -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#acompana_a">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Suplemento"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:comment>Define el vínculo entre un suplemento y el número en el que se incluye.</rdfs:comment>
        <rdfs:label>acompaña a</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_autor_de -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_autor_de">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Autor"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:comment>Define el vínculo de creación entre un autor y un contenido de su creación.</rdfs:comment>
        <rdfs:label>es autor de</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_cobertura_de -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_cobertura_de">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_cobertura"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Cobertura"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Revista"/>
        <rdfs:comment>Define el vínculo entre la cobertura de números de una revista y la publicación.</rdfs:comment>
        <rdfs:label>es cobertura de</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_dibujante_de -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_dibujante_de">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_autor_de"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_dibujante"/>
        <rdfs:domain rdf:resource="http://example.org/ontologia#Autor"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:comment>Define quién es el dibujante de un contenido.</rdfs:comment>
        <rdfs:label>es dibujante de</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_guionista_de -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_guionista_de">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_autor_de"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_guionista"/>
        <rdfs:domain rdf:resource="http://example.org/ontologia#Autor"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:comment>Define quién es el guionista de un contenido.</rdfs:comment>
        <rdfs:label>es guionista de</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_paginacion_de -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_paginacion_de">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Paginacion"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:comment>Define el vínculo entre un conjunto de páginas con el contenido que aparece en ellas.</rdfs:comment>
        <rdfs:label>es paginación de</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_periodicidad_de -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_periodicidad_de">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Periodicidad"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Revista"/>
        <rdfs:comment>Define el vínculo entre una periodicidad y la revista a la que se aplica.</rdfs:comment>
        <rdfs:label>es periodicidad de</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:comment>Define el vínculo entre un contenido y el número en que está incluido.</rdfs:comment>
        <rdfs:label>está incluido en</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#numero_con_periodicidad -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#numero_con_periodicidad">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Periodicidad"/>
        <rdfs:comment>Define el vínculo entre un número y su periodicidad.</rdfs:comment>
        <rdfs:label>número con periodicidad</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#numero_incluido -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#numero_incluido">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_numero_incluido"/>
        <rdfs:domain rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Cobertura"/>
        <rdfs:comment>Define si un número está incluido en la colección de la revista.</rdfs:comment>
        <rdfs:label>número incluido</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#numero_no_incluido -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#numero_no_incluido">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_numero_no_incluido"/>
        <rdfs:domain rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Cobertura"/>
        <rdfs:comment>Define si un número no está incluido en la colección de la revista.</rdfs:comment>
        <rdfs:label>número no incluido</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#representa_contenido -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#representa_contenido">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Imagen"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:comment>Define el vínculo entre un archivo de imagen y el contenido que aparece en él.</rdfs:comment>
        <rdfs:label>representa contenido</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_cobertura -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_cobertura">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Revista"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Cobertura"/>
        <rdfs:comment>Define el vínculo entre una revista y la cobertura de números de la colección.</rdfs:comment>
        <rdfs:label>tiene cobertura</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_dibujante -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_dibujante">
        <rdfs:subPropertyOf rdf:resource="http://example.org/ontologia#tiene_autor"/>
        <rdfs:domain rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Autor"/>
        <rdfs:comment>Define el vínculo entre un contenido y su dibujante.</rdfs:comment>
        <rdfs:label>tiene dibujante</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_guionista -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_guionista">
        <rdfs:subPropertyOf rdf:resource="http://example.org/ontologia#tiene_autor"/>
        <rdfs:domain rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Autor"/>
        <rdfs:comment>Define el vínculo entre un contenido y su guionista.</rdfs:comment>
        <rdfs:label>tiene guionista</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_numero_incluido -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_numero_incluido">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Cobertura"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:comment>Define los números de la revista incluidos en la colección.</rdfs:comment>
        <rdfs:label>tiene número incluido</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_numero_no_incluido -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_numero_no_incluido">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Cobertura"/>
        <rdfs:range rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:comment>Define si en la colección de la revista hay algún número faltante.</rdfs:comment>
        <rdfs:label>tiene número no incluido</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/ontologia#descripcion -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#descripcion">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Descripción breve de un contenido.</rdfs:comment>
        <rdfs:label>descripción de contenido</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#descripcion_revista -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#descripcion_revista">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Revista"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Descripción breve de una publicación.</rdfs:comment>
        <rdfs:label>descripción de revista</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#nombre -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#nombre">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Autor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Nombre propio de un autor.</rdfs:comment>
        <rdfs:label>nombre</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#nombre_imagen -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#nombre_imagen">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Imagen"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Nombre del archivo de imagen.</rdfs:comment>
        <rdfs:label>nombre del archivo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#num_pagina -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#num_pagina">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Imagen"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Número de página que representa un archivo de imagen determinado.</rdfs:comment>
        <rdfs:label>número de página</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#numero -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#numero">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Número que representa el orden de publicación de un número concreto.</rdfs:comment>
        <rdfs:label>número</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#pagina_fin -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#pagina_fin">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Paginacion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Página final de una paginación determinada.</rdfs:comment>
        <rdfs:label>página de fin</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#pagina_inicio -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#pagina_inicio">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Paginacion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Página inicial de una paginación determinada.</rdfs:comment>
        <rdfs:label>página de inicio</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#palabra_clave -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#palabra_clave">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Palabra clave que representa la temática de un contenido determinado.</rdfs:comment>
        <rdfs:label>palabra clave</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#pseudonimo -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#pseudonimo">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Autor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Pseudónimo de un autor determinado.</rdfs:comment>
        <rdfs:label>pseudónimo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#tipo_contenido -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#tipo_contenido">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Tipología de contenido: Cómic,  Ilustración, Texto, Texto con ilustración (texto acompañado de un dibujo), Texto con imagen (texto acompañado de imagen fotocopiada), Pasatiempo (juego, puzle, etc.), Índice, Editorial, Portada, Contraportada.</rdfs:comment>
        <rdfs:label>tipo de contenido</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#tipo_numero -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#tipo_numero">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Tipología de número. Por ejemplo, número ordinario, número especial, número recopilatorio.</rdfs:comment>
        <rdfs:label>tipo de número</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#tipo_periodo -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#tipo_periodo">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Periodicidad"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Tipo de periodicidad: Mensual, Semestral, Anual, Bianual, etc.</rdfs:comment>
        <rdfs:label>tipo de periodicidad</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#tipo_suplemento -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#tipo_suplemento">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Suplemento"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Tipología de suplemento: Suplemento, Periódico, Material promocional, etc....</rdfs:comment>
        <rdfs:label>tipo de suplemento</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#titulo_alternativo -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#titulo_alternativo">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Revista"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Título alternativo de una revista.</rdfs:comment>
        <rdfs:label>título alternativo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#titulo_contenido -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#titulo_contenido">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Título del contenido que se está describiendo.</rdfs:comment>
        <rdfs:label>título de contenido</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#titulo_revista -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#titulo_revista">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Revista"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Título de la revista.</rdfs:comment>
        <rdfs:label>título de revista</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#titulo_suplemento -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#titulo_suplemento">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Suplemento"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Título del suplemento que acompaña a un número determinado.</rdfs:comment>
        <rdfs:label>título de suplemento</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontologia#total_paginas -->


    <owl:DatatypeProperty rdf:about="http://example.org/ontologia#total_paginas">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Total de páginas de un número o suplemento.</rdfs:comment>
        <rdfs:label>total de páginas</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#anio_publicacion -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#anio_publicacion">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
        <rdfs:comment>Año de publicación de un número.</rdfs:comment>
        <rdfs:label>año de publicación</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#apellidos -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#apellidos">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Autor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Apellidos del autor.</rdfs:comment>
        <rdfs:label>apellidos</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#descontinuada -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#descontinuada">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Revista"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Identifica si la revista ha dejado de editarse y circular.</rdfs:comment>
        <rdfs:label>descontinuada</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#precio -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#precio">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Precio del número de una revista.</rdfs:comment>
        <rdfs:label>precio</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#subtitulo_revista -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#subtitulo_revista">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Revista"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Subtítulo de una revista.</rdfs:comment>
        <rdfs:label>subtítulo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#url_imagen -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#url_imagen">
        <rdfs:domain rdf:resource="http://example.org/ontologia#Imagen"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>URL donde se aloja la imagen.</rdfs:comment>
        <rdfs:label>url de imagen</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/ontologia#Autor -->


    <owl:Class rdf:about="http://example.org/ontologia#Autor">
        <rdfs:comment>Autor o autora de una pieza de contenido de la publicación.</rdfs:comment>
        <rdfs:label>Autor</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/ontologia#Contenido -->


    <owl:Class rdf:about="http://example.org/ontologia#Contenido">
        <rdfs:comment>Cada una de las piezas de contenido de un número o suplemento.</rdfs:comment>
        <rdfs:label>Contenido</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/ontologia#Imagen -->


    <owl:Class rdf:about="http://example.org/ontologia#Imagen">
        <rdfs:comment>Imagen o imágenes vinculadas a la pieza de contenido.</rdfs:comment>
        <rdfs:label>Imagen</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/ontologia#Numero -->


    <owl:Class rdf:about="http://example.org/ontologia#Numero">
        <rdfs:comment>Cada uno de los números que componen una revista.</rdfs:comment>
        <rdfs:label>Número</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/ontologia#Paginacion -->


    <owl:Class rdf:about="http://example.org/ontologia#Paginacion">
        <rdfs:comment>Páginas que abarca una pieza de contenido.</rdfs:comment>
        <rdfs:label>Paginación</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/ontologia#Periodicidad -->


    <owl:Class rdf:about="http://example.org/ontologia#Periodicidad">
        <rdfs:comment>Frecuencia de publicación.</rdfs:comment>
        <rdfs:label>Periodicidad</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/ontologia#Revista -->


    <owl:Class rdf:about="http://example.org/ontologia#Revista">
        <rdfs:comment>Publicación compuesta de diferentes números que contienen piezas de contenido.</rdfs:comment>
        <rdfs:label>Revista</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/ontologia#Suplemento -->


    <owl:Class rdf:about="http://example.org/ontologia#Suplemento">
        <rdfs:subClassOf rdf:resource="http://example.org/ontologia#Numero"/>
        <rdfs:comment>Publicación aneja e independiente de un número ordinario.</rdfs:comment>
        <rdfs:label>Suplemento</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Cobertura -->


    <owl:Class rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Cobertura">
        <rdfs:comment>Números contenidos en la colección, incluyendo los faltantes.</rdfs:comment>
        <rdfs:label>Cobertura</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Guionista -->


    <owl:Class rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Guionista">
        <rdfs:subClassOf rdf:resource="http://example.org/ontologia#Autor"/>
        <rdfs:comment>Guionista de una pieza de contenido. Suele colaborar con un dibujante.</rdfs:comment>
        <rdfs:label>Guionista</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional -->


    <owl:Class rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional">
        <rdfs:subClassOf rdf:resource="http://example.org/ontologia#Contenido"/>
        <rdfs:comment>Materiales y publicaciones adicionales de carácter promocional.</rdfs:comment>
        <rdfs:label>Material promocional</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#dibujante -->


    <owl:Class rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#dibujante">
        <rdfs:subClassOf rdf:resource="http://example.org/ontologia#Autor"/>
        <rdfs:comment>Dibujante de una pieza de contenido. Suele colaborar con un guionista.</rdfs:comment>
        <rdfs:label>Dibujante</rdfs:label>
    </owl:Class>
    


