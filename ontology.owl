    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#azagra -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#azagra">
        <rdf:type rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_azagra"/>
        <ontologia:descripcion>Dibujo original y autógrafo del reconocido historietista Carlos Azagra, enviado desde Santa Coloma de Gramanet (Barcelona) como correspondencia para la redacción. La ilustración muestra a un personaje caricaturesco (estilo característico de su obra, similar a los del grupo P.G.B.) gritando con entusiasmo &quot;ESE FANCHINEE !!&quot; mientras señala un sobre cerrado, incluyendo debajo la firma del autor y su dirección postal en el Apartado 21 (código postal 08921).</ontologia:descripcion>
        <ontologia:tipo_contenido>Dibujos</ontologia:tipo_contenido>
        <rdfs:label>Azagra</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#barony -->


