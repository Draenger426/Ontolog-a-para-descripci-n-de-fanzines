    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#contraportada10 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#contraportada10">
