        <ontologia:palabra_clave>Romance</ontologia:palabra_clave>
        <ontologia:tipo_contenido>Portada</ontologia:tipo_contenido>
        <rdfs:label>Portada #seccion1002</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#portada_sti_01 -->


