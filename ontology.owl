        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num08"/>
        <tiene_dibujante rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#david_casado"/>
        <ontologia:descripcion>Dibujo de un duelo entre un vigilante de aparcamientos y un motorista al estilo oeste. El duelo sucede en la facultad de ciencias de la UGR.</ontologia:descripcion>
