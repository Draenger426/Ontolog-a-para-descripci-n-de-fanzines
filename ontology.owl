        <ontologia:tiene_paginacion rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag_contraeditorial09"/>
        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num09"/>
        <ontologia:descripcion>Nota editorial que aparece casi al final del número. Viene acompañado de un dibujo de Gork.</ontologia:descripcion>
        <ontologia:tipo_contenido>Editorial</ontologia:tipo_contenido>
        <rdfs:label>Contraeditorial del número 9</rdfs:label>
