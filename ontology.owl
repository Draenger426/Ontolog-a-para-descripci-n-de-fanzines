    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#calendario04 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#calendario04">
        <rdf:type rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_calendario0401"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_calendario0402"/>
        <ontologia:descripcion>Calendario de bolsillo de 1997 publicitario del &quot;Café Bar LAS TORRES&quot;, un establecimiento clásico situado en la calle Trucha del barrio de La Chana (Granada), regentado por José Puertas Díaz y famoso por sus &quot;tapas variadas y caracoles&quot;. El lote se completa con una tarjeta satírica sobre gestión laboral (&quot;Escoja usted&quot;), que ilustra el clásico &quot;triángulo de la calidad&quot; obligando al cliente a elegir solo dos opciones entre un trabajo &quot;Barato, Rápido y Bueno&quot;, advirtiendo que la combinación de las tres es imposible.</ontologia:descripcion>
        <ontologia:tipo_contenido>Calendario</ontologia:tipo_contenido>
        <rdfs:label>Calendario #04</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#certamen_humor -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#certamen_humor">
        <rdf:type rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_certamen"/>
        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num12"/>
        <ontologia:descripcion>Cartel informativo del &quot;I CERTAMEN DE HUMOR SAN ALBERTO MAGNO&quot;, un concurso organizado por la Asociación Cultural Radical Al Kilo que abarca categorías de redacción, fotografía y humor gráfico. La ilustración central muestra a un personaje ambicioso gritando &quot;¡LO QUIERO TODOO!&quot; desde un despacho caótico lleno de humo y objetos extraños (incluyendo un pollo colgado), mientras un operario termina de pegar el cartel en una valla publicitaria. El evento cuenta con el patrocinio institucional del Vicerrectorado de Estudiantes y la colaboración de la Casa de Porras y la Facultad de Ciencias, dirigiendo a los interesados a la Sala de Alumnos o al apartado de correos 1275 de Granada.</ontologia:descripcion>
        <ontologia:tipo_contenido>Texto con dibujo</ontologia:tipo_contenido>
        <ontologia:titulo_contenido>I CERTAMEN DE HUMOR SAN ALBERTO MAGNO</ontologia:titulo_contenido>
        <rdfs:label>I Certamen de Humor</rdfs:label>
    </owl:NamedIndividual>
    


