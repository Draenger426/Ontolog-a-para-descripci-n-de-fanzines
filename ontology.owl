        <ontologia:tiene_paginacion rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0416"/>
        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num04"/>
        <tiene_dibujante rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pedro_gadicto"/>
        <tiene_guionista rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pedro_gadicto"/>
        <ontologia:descripcion>Historieta que narra la venganza de un Zeus enfadado por el olvido de los mortales tras 2000 años de vacaciones. El dios reúne a un panteón multicultural (con cameos telefónicos de deidades egipcias y nórdicas) para sembrar el caos en la Tierra: provocan accidentes de tráfico masivos entre risas y Neptuno juega literalmente a &quot;hundir la flota&quot; con barcos reales, cerrando la historia con una explosión nuclear de Ares y un cliffhanger que anticipa la llegada de Jesucristo y Alá.</ontologia:descripcion>
        <ontologia:palabra_clave>Mitología girega</ontologia:palabra_clave>
        <ontologia:palabra_clave>Religión</ontologia:palabra_clave>
        <ontologia:tipo_contenido>Cómic</ontologia:tipo_contenido>
        <ontologia:titulo_contenido>Olympo: Una historia divina</ontologia:titulo_contenido>
        <rdfs:label>Contenido #0416</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0417 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0417">
        <rdf:type rdf:resource="http://example.org/ontologia#Contenido"/>
