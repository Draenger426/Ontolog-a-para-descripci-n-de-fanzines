    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0103 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0103">
        <rdf:type rdf:resource="http://example.org/ontologia#Contenido"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0109"/>
        <ontologia:tiene_paginacion rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0103"/>
        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"/>
        <ontologia:descripcion>Retrata la apatía vital de un estudiante deprimido que hace todo por inercia: estudia Biológicas aunque quiere ser bombero, sale de marcha aunque se aburre y escucha a Modern Talking aunque le duele la cabeza. La historieta concluye definiendo científicamente la inercia como la resistencia al cambio de estado, aplicándola irónicamente a su propia vida vacía.</ontologia:descripcion>
        <ontologia:palabra_clave>Crítica social</ontologia:palabra_clave>
        <ontologia:palabra_clave>Estudiantes</ontologia:palabra_clave>
        <ontologia:tipo_contenido>Cómic</ontologia:tipo_contenido>
        <ontologia:titulo_contenido>Inercia</ontologia:titulo_contenido>
        <rdfs:label>Contenido #0103</rdfs:label>
    </owl:NamedIndividual>
    


