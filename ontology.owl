    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0104 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0104">
        <rdf:type rdf:resource="http://example.org/ontologia#Contenido"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0110"/>
        <ontologia:tiene_autor rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#a_saavedra"/>
        <ontologia:tiene_paginacion rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0104"/>
        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"/>
        <ontologia:descripcion>Exclusiva con el bíblico Noé, encontrado de juerga en un chiringuito, quien confiesa que el Diluvio Universal fue un invento y que construyó el Arca únicamente para &quot;irse de marcha&quot; con los colegas por Marbella y la calle Pedro Antonio. El patriarca se muestra decepcionado con el ecologismo (preguntando si es &quot;alguna droga&quot;) y se queja de la borrachera de los animales a bordo, todo ello maquetado con una estética de fanzine punk con letras recortadas tipo anónimo bajo el sello &quot;AHÍ QUEDA ESO&quot;.</ontologia:descripcion>
        <ontologia:palabra_clave>Parodia</ontologia:palabra_clave>
        <ontologia:palabra_clave>Religión</ontologia:palabra_clave>
        <ontologia:tipo_contenido>Texto</ontologia:tipo_contenido>
        <ontologia:titulo_contenido>¡Qué NOE-stas AL LORO, COLEGA!</ontologia:titulo_contenido>
        <rdfs:label>Contenido #0104</rdfs:label>
    </owl:NamedIndividual>
    


