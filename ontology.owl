    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#editorial01 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#editorial01">
        <rdf:type rdf:resource="http://example.org/ontologia#Contenido"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0102"/>
        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"/>
        <ontologia:descripcion>Tablón de anuncios policial de &quot;TOP SECRET&quot; y &quot;CASOS PERDIDOS&quot;, donde los miembros del equipo son presentados como delincuentes en una lista de &quot;SE BUSCAN&quot; y &quot;ENEMIGOS PÚBLICOS&quot;. Cada redactor tiene una ficha con caricatura, alias y delitos absurdos: M. Talavera (Alias Fusta) por &quot;extorsión al obrero&quot;, A. Vargas (Alias Retoque) por pintar bigotes en carteles, A. Martínez (Alias Cutre) por prácticas de &quot;sado-maso a transeúntes&quot; o Enrique López (Alias Quiller), señalado por negarse a escribir su nombre con &apos;K&apos; porque &quot;eso era punky&quot;, completando así el staff de RADICAL.</ontologia:descripcion>
        <ontologia:tipo_contenido>Editorial</ontologia:tipo_contenido>
        <rdfs:label>Editorial del número 1</rdfs:label>
    </owl:NamedIndividual>
    


