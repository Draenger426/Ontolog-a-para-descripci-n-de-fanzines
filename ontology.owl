        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num06"/>
        <ontologia:descripcion>Parodia de las series de televisión (tipo Falcon Crest) utilizada para presentar al equipo del fanzine. Describe con humor ácido a los redactores: David (&quot;Jefe desorganizador&quot;), Pedro (&quot;Delincuente pornográfico&quot;), Antonio Jesús (&quot;Beatorro&quot;), Ignacio (&quot;Asesino en potencia&quot;), Omar y Fernando. Incluye diálogos ficticios en el &quot;Valle de Tuscany&quot;</ontologia:descripcion>
        <ontologia:palabra_clave>Parodias</ontologia:palabra_clave>
        <ontologia:palabra_clave>RAK</ontologia:palabra_clave>
        <ontologia:tipo_contenido>Texto</ontologia:tipo_contenido>
        <ontologia:titulo_contenido>Radical Crest</ontologia:titulo_contenido>
        <rdfs:label>Contenido #0606</rdfs:label>
    </owl:NamedIndividual>
    


