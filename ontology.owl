    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#bocetos -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#bocetos">
        <rdf:type rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_boceto01"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_boceto02"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_boceto03"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_boceto04"/>
        <ontologia:descripcion>Conjunto de material gráfico que ilustra el proceso creativo y promocional del fanzine. La serie incluye una viñeta entintada de temática sci-fi donde un alienígena monstruoso declara &quot;MI MAMÁ TAMBIÉN LO LEE&quot;, junto a hojas de bocetos a lápiz que exploran ideas como &quot;LA TENTACIÓN&quot; (una parodia bíblica con Adán y Eva cubriéndose con la revista). También se presenta un esquema de maquetación (storyboard) planificando paneles informativos sobre la identidad del grupo (&quot;Quiénes somos&quot;, &quot;Cómo se hace&quot;) y eslóganes de captación como &quot;Yo aprendo Radical Alkilo&quot;.</ontologia:descripcion>
        <ontologia:tipo_contenido>Dibujos</ontologia:tipo_contenido>
        <rdfs:label>Bocetos</rdfs:label>
    </owl:NamedIndividual>
    


