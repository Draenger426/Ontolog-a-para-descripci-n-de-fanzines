        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num10"/>
        <ontologia:descripcion>Foto calcada de un hombre fumando un puro. Encima del puro se puede ver a un ave apoyado. Esta portada da entrada ala sección de cine del número 10 de RAK.</ontologia:descripcion>
        <ontologia:palabra_clave>Cine</ontologia:palabra_clave>
        <ontologia:tipo_contenido>Portada</ontologia:tipo_contenido>
        <rdfs:label>Portada #seccion1001</rdfs:label>
