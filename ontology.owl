    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#acta__fundacional -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#acta__fundacional">
        <rdf:type rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta01"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta02"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta03"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta04"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta05"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta06"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta07"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta08"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta09"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta10"/>
        <ontologia:descripcion>Documentación legal administrativa que formaliza la constitución de la Asociación Cultural &quot;RADICAL AL KILO&quot; (R.A.K.), elevando el fanzine a entidad oficial registrada en la Junta de Andalucía con el número 1.944. El conjunto incluye el Acta Fundacional firmada en la Facultad de Ciencias el 28 de diciembre de 1991 (coincidiendo irónicamente con el Día de los Santos Inocentes) por siete socios fundadores, entre ellos Antonio Javier Muñoz Benítez y Bruno José Jiménez Guisado. Se adjuntan los Estatutos aprobados en 1992, que establecen el carácter no lucrativo de la asociación, fijan su patrimonio inicial en 10.000 pesetas, definen la revista como su &quot;órgano de expresión&quot; principal y protegen legalmente el uso exclusivo de las siglas R.A.K. frente a terceros.</ontologia:descripcion>
        <ontologia:tipo_contenido>Texto</ontologia:tipo_contenido>
        <ontologia:titulo_contenido>Acta Fundacional de la Asociación Cultural &apos;Radikal al Kilo&apos;</ontologia:titulo_contenido>
        <rdfs:label>Acta Fundacional de la Asociación Cultural Radical al Kilo</rdfs:label>
