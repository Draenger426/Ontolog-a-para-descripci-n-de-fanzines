        <ontologia:descripcion>Viñeta didáctica absurda. Pregunta: &quot;¿Qué es la masa?&quot;. Opciones: &quot;La masa eres tú&quot;, &quot;Un monstruo&quot;, &quot;Un pastel&quot;, &quot;Un montón de gente (palurdos)&quot;. Solución: &quot;Claramente es un monstruo&quot;.</ontologia:descripcion>
        <ontologia:palabra_clave>Física</ontologia:palabra_clave>
        <ontologia:tipo_contenido>Cómic</ontologia:tipo_contenido>
        <ontologia:titulo_contenido>Curso avanzado de físicas: Tema primero</ontologia:titulo_contenido>
        <rdfs:label>Contenido #0629</rdfs:label>
    </owl:NamedIndividual>
    


