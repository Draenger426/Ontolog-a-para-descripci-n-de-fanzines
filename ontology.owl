        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0440"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0441"/>
