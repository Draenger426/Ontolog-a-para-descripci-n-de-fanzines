        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num_recopilatorio"/>
        <ontologia:descripcion>La portada recopila, en miniatura, las portadas de los anteriores números en imágenes.</ontologia:descripcion>
