    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#sado -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#sado">
        <rdf:type rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_sado01"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_sado02"/>
        <ontologia:descripcion>Cartel promocional de doble cara que anuncia en su anverso un ficticio &quot;Día Internacional del Sado-Maso&quot; para la fecha imposible del 31 de abril de 1987, ilustrado con un dibujo de bondage y la promesa irónica de regalar una fusta a quien visite al colectivo. El reverso funciona como un boletín musical de estética punk titulado &quot;K-TES Y NIETOS&quot; (leído entre garabatos), que ofrece &quot;primicias mundiales&quot; sobre lanzamientos de la discográfica DRO y grupos como Siniestro Total, La Fura del Baus, Glutamato Ye-Ye o Eskorbuto, todo ello bajo el epígrafe de &quot;La Pág. Sin Nº (Diskriminación)&quot; y firmado por &quot;Melenas &amp; Mutante&quot;.</ontologia:descripcion>
        <ontologia:tipo_contenido>Portada</ontologia:tipo_contenido>
        <ontologia:tipo_contenido>Texto</ontologia:tipo_contenido>
        <rdfs:label>Día Internacional del Sado</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#seccion0001 -->


