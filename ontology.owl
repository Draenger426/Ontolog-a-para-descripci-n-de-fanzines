    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#reyes_vagos -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#reyes_vagos">
        <rdf:type rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_cartareyes"/>
        <ontologia:descripcion>Flyer satírico navideño de 1991 titulado &quot;Queridos Reyes Vagos&quot;, diseñado a modo de plantilla epistolar para que los lectores participen en un concurso de cartas. El texto invita a pedir regalos a una versión denigrante de los Reyes Magos, rebautizados como Melchor-izo, Gaspar-turiento y Baltasar-noso (que &quot;se han apuntado a Radical Al Kilo&quot;), ofreciendo como premio el sorteo de 2 botellas de cava entre las peticiones más originales. La composición visual es un collage de grabados antiguos de querubines y muñecos (firmados como &quot;Los muñequitos de POTOSA&quot;) que lanzan frases sugerentes como &quot;¡Hazme tuyo!&quot;, todo ello bajo el deseo desganado de una &quot;Feliz Navidad y tó éso&quot;.</ontologia:descripcion>
        <ontologia:tipo_contenido>Dibujo</ontologia:tipo_contenido>
        <rdfs:label>Carta de Reyes Vagos</rdfs:label>
    </owl:NamedIndividual>
    


