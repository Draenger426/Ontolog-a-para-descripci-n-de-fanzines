    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#calendario003 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#calendario003">
        <rdf:type rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_calendario0301"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_calendario0302"/>
        <ontologia:descripcion>Calendario del año 1999. Viene acompañado de un dibujo de un señor mayor de vacaciones celebrando que por fin acabó la universidad.</ontologia:descripcion>
        <ontologia:tipo_contenido>Calendario</ontologia:tipo_contenido>
