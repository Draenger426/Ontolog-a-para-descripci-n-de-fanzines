        <ontologia:tiene_autor rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pedro_gadicto"/>
        <ontologia:tiene_paginacion rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0632"/>
        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num06"/>
        <ontologia:descripcion>Cuarta parte de la historia de Pedro y Laura. El grupo entra en la &quot;Cueva de la Gitana&quot;. En la oscuridad, Laura plantea el &quot;Enigma de las cerezas&quot; (el niño que no tenía cerezas, subió al cerezo que no tenía cerezas...). Pedro lo resuelve (jugando con el plural y singular). Salen de la cueva y planean una barbacoa.</ontologia:descripcion>
        <ontologia:palabra_clave>Relatos</ontologia:palabra_clave>
        <ontologia:tipo_contenido>Texto</ontologia:tipo_contenido>
        <ontologia:titulo_contenido>Enigmas 4</ontologia:titulo_contenido>
        <rdfs:label>Contenido #0632</rdfs:label>
    </owl:NamedIndividual>
    


