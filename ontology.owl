        <ontologia:tipo_contenido>Portada</ontologia:tipo_contenido>
        <rdfs:label>Portada del número 11</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#portada12 -->


