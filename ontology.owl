        <esta_incluido_en rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num12"/>
        <ontologia:descripcion>Dibujo que de un hombre-bestia que recuerda a Lobezno, anunciando que está disponible el número 12 de RAK  a 12 pesetas.</ontologia:descripcion>
        <ontologia:tipo_contenido>Portada</ontologia:tipo_contenido>
