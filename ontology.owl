        <tiene_guionista rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#fernando_nante_desemen"/>
        <ontologia:descripcion>Historieta de acción protagonizada por un escuadrón policial &quot;Antivicio&quot; que asalta la facultad buscando &quot;el contaminado&quot; (el fanzine). Los agentes, dibujados con estilo de superhéroes grotescos, atacan los servicios y detienen a un estudiante por leer el &quot;Radical&quot;.</ontologia:descripcion>
        <ontologia:palabra_clave>RAK</ontologia:palabra_clave>
        <ontologia:tipo_contenido>Cómic</ontologia:tipo_contenido>
        <ontologia:titulo_contenido>La corrupción</ontologia:titulo_contenido>
        <rdfs:label>Contenido #0604</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0605 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0605">
        <rdf:type rdf:resource="http://example.org/ontologia#Contenido"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0613"/>
