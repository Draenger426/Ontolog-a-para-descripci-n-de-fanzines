    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0632">
        <rdf:type rdf:resource="http://example.org/ontologia#Contenido"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0689"/>
