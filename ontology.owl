    <!-- http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#marcapaginas_navidad -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#marcapaginas_navidad">
        <rdf:type rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_navidad01"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_navidad02"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_navidad03"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_navidad04"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_navidad05"/>
        <ontologia:aparece_en_imagen rdf:resource="http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_navidad06"/>
        <ontologia:descripcion>Colección de marcapáginas satíricos editados en 1995 bajo la serie irónica &quot;I Love...&quot;, ilustrados por AJTG (Antonio Jesús Torres Gil). Las viñetas cargan con humor negro contra la vida universitaria y la actualidad: desde la ruina económica estudiantil por los &quot;Precios Públicos&quot; y la crueldad de los &quot;Catedráticos&quot; y &quot;Profesores Huesos&quot; (representados como cerdos o puertas aplastantes), hasta el deseo de dinamitar la Facultad o la crítica a las pruebas nucleares francesas en Mururoa mediante un esqueleto hawaiano.</ontologia:descripcion>
        <ontologia:tipo_contenido>Marcapáginas</ontologia:tipo_contenido>
        <rdfs:label>Marcapáginas de Navidad</rdfs:label>
    </owl:NamedIndividual>
    


