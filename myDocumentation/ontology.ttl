###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0615
:con0615 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0646 ,
                                                          :img0647 ,
                                                          :img0648 ,
                                                          :img0649 ;
         <http://example.org/ontologia#tiene_autor> :pedro_gadicto ;
         <http://example.org/ontologia#tiene_paginacion> :pag0615 ;
         :esta_incluido_en :num06 ;
         <http://example.org/ontologia#descripcion> "Tercera parte de la saga de los enigmas. Tras llegar a una fuente, Laura plantea un nuevo acertijo: una variante del anterior con un rey \"más bondadoso pero corto de luces\" que envía una segunda carta prohibiendo matar a las esposas. Pedro vuelve a deducir la solución lógica sobre las mujeres fieles e infieles. Llegan Mamen y Soledad agotadas a la fuente." ;
         <http://example.org/ontologia#palabra_clave> "Relatos" ;
         <http://example.org/ontologia#tipo_contenido> "Texto" ;
         <http://example.org/ontologia#titulo_contenido> "Enigmas 3" ;
         rdfs:label "Contenido #0615" .


