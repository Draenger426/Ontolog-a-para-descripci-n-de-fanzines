###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#postal_navidad
:postal_navidad rdf:type owl:NamedIndividual ,
                         :Material_promocional ;
                <http://example.org/ontologia#aparece_en_imagen> :img_postal01 ,
                                                                 :img_postal02 ,
                                                                 :img_postal03 ;
                <http://example.org/ontologia#descripcion> "Postal de felicitación navideña de 1989, ilustrada por AJTG, que parodia el reparto del fanzine. La imagen principal muestra a un Papá Noel enloquecido pilotando un \"TURBO TRINEO GLX OPEL\" desbordado de revistas \"RADICAL AL KILO\" que salen volando por los aires. El interior incluye un mensaje de \"Felices Fiestas\" en tipografía gótica dentro de un bocadillo explosivo, y el reverso firma irónicamente como \"RADICAL AL KILO S.A.\" (Sociedad Anónima), fechando el documento en 1989." ;
                <http://example.org/ontologia#tipo_contenido> "Postal" ;
                rdfs:label "Postal de Navidad" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#principios
:principios rdf:type owl:NamedIndividual ,
                     :Material_promocional ;
            <http://example.org/ontologia#aparece_en_imagen> :img_principio ;
            :esta_incluido_en :num02 ;
            <http://example.org/ontologia#descripcion> "Resumen de algunas leyes y principios básicos que se enseñan en ciencias." ;
            <http://example.org/ontologia#tipo_contenido> "Texto" ;
            rdfs:label "Principios básicos de la ciencia" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#radikal_al_kilo
:radikal_al_kilo rdf:type owl:NamedIndividual ,
                          <http://example.org/ontologia#Revista> ;
                 <http://example.org/ontologia#tiene_periodicidad> :periodicidad_revista ;
                 :tiene_cobertura :cob_radikal ;
                 <http://example.org/ontologia#descripcion_revista> "Fanzine creado por los alumnos de la Facultad de Ciencias de la Universidad de Granada entre los 80 y 90. Se compone de 13 números y varios suplementos que iban junto a estos (ya sean periódicos u otra revista alternativa llamada Radikal Stylo)." ;
                 <http://example.org/ontologia#titulo_alternativo> "RAK" ;
                 <http://example.org/ontologia#titulo_revista> "Radikal Al Kilo" ;
                 :descontinuada "true"^^xsd:boolean ;
                 :subtitulo_revista "El fanzine cuántico" ;
                 rdfs:label "Radikal Al Kilo" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#radikal_sstilo_01
