                                                          :con0104_sti ,
                                                          :con0105_sti ,
                                                          :contraportada_sti_01 ,
                                                          :editorial_sti_01 ,
                                                          :indice_sti_01 ,
                                                          :portada_sti_01 ;
                   :acompana_a :num08 ;
                   <http://example.org/ontologia#numero> 1 ;
                   <http://example.org/ontologia#tipo_suplemento> "Revista complementaria" ;
                   <http://example.org/ontologia#titulo_suplemento> "Radikal Sstilo" ;
                   <http://example.org/ontologia#total_paginas> 16 ;
                   :anio_publicacion "1991"^^xsd:gYear ;
                   rdfs:label "sup Radikal Sstilo 1" .


