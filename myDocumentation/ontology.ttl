###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0509
:con0509 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0520 ;
         <http://example.org/ontologia#tiene_autor> :pedro_gadicto ;
         <http://example.org/ontologia#tiene_paginacion> :pag0509 ;
         :esta_incluido_en :num05 ;
         <http://example.org/ontologia#descripcion> "Un crucigrama gigante con definiciones de cultura pop y local (\"Buda\", \"Río sudaca\", \"Cantante de The Cure\")." ;
         <http://example.org/ontologia#palabra_clave> "Crucigramas" ;
         <http://example.org/ontologia#tipo_contenido> "Pasatiempos" ;
         <http://example.org/ontologia#titulo_contenido> "Crucigrama" ;
         rdfs:label "Contenido #0509" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0510
:con0510 rdf:type owl:NamedIndividual ,
