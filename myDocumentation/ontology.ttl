         <http://example.org/ontologia#tiene_paginacion> :pag0621 ;
         :esta_incluido_en :num06 ;
         :tiene_dibujante :fernando_nante_desemen ;
         :tiene_guionista :fernando_nante_desemen ;
         <http://example.org/ontologia#descripcion> "Falso anuncio de trabajo (\"Empresa en expansión\") buscando personas con aspecto \"tétrico y escalofriante\", \"socialmente distante\" y \"endiabladamente odioso\" para el puesto de Fogonero en el infierno (\"Nosotros nos encargamos de ponerle los cuernos\")." ;
         <http://example.org/ontologia#palabra_clave> "Publicidad" ;
         <http://example.org/ontologia#tipo_contenido> "Parodia pubicitaria" ;
         rdfs:label "Contenido #0621" .


