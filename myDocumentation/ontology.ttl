###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0623
:con0623 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0670 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0623 ;
         :esta_incluido_en :num06 ;
         <http://example.org/ontologia#descripcion> "Macabra caricatura en la que un docente, a pesar de haber sufrido un atentado de sus alumnos, amenaza con continuar suspendíéndoles." ;
         <http://example.org/ontologia#palabra_clave> "Docencia" ;
         <http://example.org/ontologia#tipo_contenido> "Ilustración" ;
         rdfs:label "Contenido #0623" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0624
:con0624 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0671 ,
                                                          :img0672 ;
         <http://example.org/ontologia#tiene_autor> :fernando_nante_desemen ,
                                                    :pedro_gadicto ;
         <http://example.org/ontologia#tiene_paginacion> :pag0624 ;
         :esta_incluido_en :num06 ;
         <http://example.org/ontologia#descripcion> "Texto de auto-psicoanálisis satírico que explica el origen del odio de los redactores hacia los bedeles y señoras de la limpieza. Narra una infancia traumática donde fueron confundidos con trapos sucios, lavados con lejía y agredidos con croissants por camareros. Cita teorías de psiquiatras ficticios (Dr. Paco Mouna Cabration, Dr. Andrés Quizofrénico) sobre defectos genéticos o parentesco con Woody Allen." ;
         <http://example.org/ontologia#palabra_clave> "Relatos" ;
         <http://example.org/ontologia#tipo_contenido> "Texto" ;
         <http://example.org/ontologia#titulo_contenido> "Temas de nuestra época: El trauma de los radicales" ;
         rdfs:label "Contenido #0624" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0625
:con0625 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0675 ,
                                                          :img0676 ,
                                                          :img0677 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0625 ;
         :esta_incluido_en :num06 ;
         :tiene_dibujante :mike ;
         :tiene_guionista :mike ;
         <http://example.org/ontologia#descripcion> "Historieta sobre Oscar, un joven que quiere ligar y decide comprarse un coche. Tras ser rechazado con su Simca 1000, visita concesionarios de lujo (Ramborghini, Ferrari Tetarosa). Al final compra el coche de su abuelo (\"Kacho Karro\") y liga con una chica que resulta ser una reina africana, parodiando la película El Príncipe de Zamunda." ;
         <http://example.org/ontologia#palabra_clave> "Humor" ;
         <http://example.org/ontologia#tipo_contenido> "Cómic" ;
         <http://example.org/ontologia#titulo_contenido> "La fuerza del cariño" ;
         :nota "No tiene la página 74" ;
         rdfs:label "Contenido #0625" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0626
:con0626 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0678 ;
         <http://example.org/ontologia#tiene_autor> :ignacio_nalista ;
         <http://example.org/ontologia#tiene_paginacion> :pag0626 ;
         :esta_incluido_en :num06 ;
         <http://example.org/ontologia#descripcion> "Laberinto en el que se propone llegar a tiempo al examen de termo estando en un atasco en “la M-20”." ;
         <http://example.org/ontologia#palabra_clave> "Laberintos" ;
         <http://example.org/ontologia#tipo_contenido> "Pasatiempos" ;
         rdfs:label "Contenido #0626" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0627
:con0627 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0679 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0627 ;
         :esta_incluido_en :num06 ;
         <http://example.org/ontologia#descripcion> "Portada alternativa tachada y criticada por el G.A.L. (Grupo de Amotinados Libertinos), quejándose de que David siempre sale en las fotos y de la calidad del fanzine (\"¿Mañana en piedra?\")." ;
         <http://example.org/ontologia#tipo_contenido> "Portada" ;
         rdfs:label "Contenido #0627" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0628
:con0628 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0680 ,
                                                          :img0681 ,
                                                          :img0682 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0628 ;
         :esta_incluido_en :num06 ;
         :tiene_dibujante :fernando_nante_desemen ;
         :tiene_guionista :fernando_nante_desemen ;
         <http://example.org/ontologia#descripcion> "Historieta de aventuras donde un protagonista escapa de unos experimentos en una isla y se enfrenta a soldados. El estilo es de acción caótica con tiroteos y explosiones (\"Paw Paw\", \"Boom\"). Final abierto o confuso (\"No se supo más...\")." ;
         <http://example.org/ontologia#palabra_clave> "Acción" ;
         <http://example.org/ontologia#tipo_contenido> "Cómic" ;
         <http://example.org/ontologia#titulo_contenido> "Macumba" ;
         rdfs:label "Contenido #0628" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0629
:con0629 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0683 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0629 ;
         :esta_incluido_en :num06 ;
         :tiene_dibujante :fernando_nante_desemen ;
         :tiene_guionista :fernando_nante_desemen ;
         <http://example.org/ontologia#descripcion> "Viñeta didáctica absurda. Pregunta: \"¿Qué es la masa?\". Opciones: \"La masa eres tú\", \"Un monstruo\", \"Un pastel\", \"Un montón de gente (palurdos)\". Solución: \"Claramente es un monstruo\"." ;
         <http://example.org/ontologia#palabra_clave> "Física" ;
         <http://example.org/ontologia#tipo_contenido> "Cómic" ;
         <http://example.org/ontologia#titulo_contenido> "Curso avanzado de físicas: Tema primero" ;
         rdfs:label "Contenido #0629" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0630
:con0630 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0684 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0630 ;
         :esta_incluido_en :num06 ;
         :tiene_dibujante :antonio_torres_gil ;
         <http://example.org/ontologia#descripcion> "Página de publicidad antidrogas satírica, que, en su lugar, incita a beber vino. Incluye imágenes de asesinatos, exhibicionismo publico, tabaco…" ;
         <http://example.org/ontologia#palabra_clave> "Publicidad" ;
         <http://example.org/ontologia#tipo_contenido> "Parodia publicitaria" ;
         rdfs:label "Contenido #0630" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0631
:con0631 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0685 ,
                                                          :img0686 ,
                                                          :img0687 ,
                                                          :img0688 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0631 ;
         :esta_incluido_en :num06 ;
         :tiene_dibujante :ignacio_nalista ;
         :tiene_guionista :ignacio_nalista ;
         <http://example.org/ontologia#descripcion> "Collage de fotografías con \"bocadillos\" de texto superpuestos para crear situaciones cómicas fuera de contexto (parecido a las fotonovelas de revistas del corazón). Incluye chistes en alemán macarrónico y situaciones absurdas." ;
         <http://example.org/ontologia#palabra_clave> "Fotografía" ;
         <http://example.org/ontologia#tipo_contenido> "Cómic" ;
         <http://example.org/ontologia#titulo_contenido> "Objetivo indiscreto" ;
         rdfs:label "Contenido #0631" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0632
:con0632 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0689 ,
                                                          :img0690 ,
                                                          :img0691 ;
         <http://example.org/ontologia#tiene_autor> :pedro_gadicto ;
         <http://example.org/ontologia#tiene_paginacion> :pag0632 ;
         :esta_incluido_en :num06 ;
         <http://example.org/ontologia#descripcion> "Cuarta parte de la historia de Pedro y Laura. El grupo entra en la \"Cueva de la Gitana\". En la oscuridad, Laura plantea el \"Enigma de las cerezas\" (el niño que no tenía cerezas, subió al cerezo que no tenía cerezas...). Pedro lo resuelve (jugando con el plural y singular). Salen de la cueva y planean una barbacoa." ;
         <http://example.org/ontologia#palabra_clave> "Relatos" ;
         <http://example.org/ontologia#tipo_contenido> "Texto" ;
         <http://example.org/ontologia#titulo_contenido> "Enigmas 4" ;
         rdfs:label "Contenido #0632" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0633
:con0633 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0692 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0633 ;
         :esta_incluido_en :num06 ;
         :tiene_dibujante :fernando_nante_desemen ;
         :tiene_guionista :fernando_nante_desemen ;
         <http://example.org/ontologia#descripcion> "Historieta donde un personaje borracho cambia de personalidad constantemente: atleta (\"Ben Johnson\"), Superman, etc., hasta caer al suelo." ;
         <http://example.org/ontologia#palabra_clave> "Humor" ;
         <http://example.org/ontologia#tipo_contenido> "Cómic" ;
         <http://example.org/ontologia#titulo_contenido> "Personalidad múltiple" ;
         rdfs:label "Contenido #0633" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0634
:con0634 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0693 ,
                                                          :img0694 ,
                                                          :img0695 ;
         <http://example.org/ontologia#tiene_autor> :pedro_gadicto ;
         <http://example.org/ontologia#tiene_paginacion> :pag0634 ;
         :esta_incluido_en :num06 ;
         <http://example.org/ontologia#descripcion> "Conclusión de la saga. De vuelta en el pueblo, tomando café, Laura plantea el clásico \"Enigma del camarero y las pesetas\" (3 amigos pagan 7 ptas, les devuelven 5, falta una peseta...). Pedro, prepotente, explica el error de planteamiento matemático. El resto del grupo (Mamen, Antonio) acaba harto de los enigmas y de la inteligencia de Pedro." ;
         <http://example.org/ontologia#palabra_clave> "Relatos" ;
         <http://example.org/ontologia#tipo_contenido> "Texto" ;
         <http://example.org/ontologia#titulo_contenido> "Enigmas 5" ;
         rdfs:label "Contenido #0634" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0635
:con0635 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0696 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0635 ;
         :esta_incluido_en :num06 ;
         <http://example.org/ontologia#descripcion> "Noticias absurdas (\"Hallados restos del Titanic bajo un pupitre\", \"Huelga de bedeles tipo japonés\")." ;
         <http://example.org/ontologia#tipo_contenido> "Texto" ;
         <http://example.org/ontologia#titulo_contenido> "Breves" ;
         rdfs:label "Contenido #0635" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0636
