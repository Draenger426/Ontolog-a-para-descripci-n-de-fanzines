         <http://example.org/ontologia#tipo_contenido> "Publicidad" ;
         rdfs:label "Contenido #0417" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0418
:con0418 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
