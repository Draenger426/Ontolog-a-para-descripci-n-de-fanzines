@prefix : <http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#> .

<http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2> rdf:type owl:Ontology ;
                                                                             <http://purl.org/dc/elements/1.1/creator> "Hutman Ahmed Mohamed" ,
                                                                                                                       "José Manuel Morales del Castillo" ,
                                                                                                                       "Ángel Arcos Sánchez" ;
                                                                             <http://purl.org/dc/elements/1.1/description> "Ontología para la descripción de fanzines. Se ha tomado como base el fanzine \"Radikal Al Kilo\", que se publicó entre los años 80 y 90 del siglo XX en la Facultad de Ciencias de la Universidad de Granada." ;
                                                                             <http://purl.org/dc/elements/1.1/title> "Ontología para descripción de fanzines" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/author
<http://purl.org/dc/elements/1.1/author> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/date
<http://purl.org/dc/elements/1.1/date> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/summary
<http://purl.org/dc/elements/1.1/summary> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#nota
:nota rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#ontologyIRI
owl:ontologyIRI rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#gYear
xsd:gYear rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/ontologia#aparece_en_imagen
<http://example.org/ontologia#aparece_en_imagen> rdf:type owl:ObjectProperty ;
                                                 owl:inverseOf :representa_contenido ;
                                                 rdfs:domain <http://example.org/ontologia#Contenido> ;
                                                 rdfs:range <http://example.org/ontologia#Imagen> ;
                                                 rdfs:comment "Define el vínculo entre un contenido y el archivo de imagen en la que aparece digitalizado." ;
                                                 rdfs:label "aparece en imagen" .


###  http://example.org/ontologia#incluye
<http://example.org/ontologia#incluye> rdf:type owl:ObjectProperty ;
                                       owl:inverseOf :esta_incluido_en ;
                                       rdfs:domain <http://example.org/ontologia#Numero> ;
                                       rdfs:range <http://example.org/ontologia#Contenido> ;
                                       rdfs:comment "Define el vínculo entre un número y un contenido específico que incluye." ;
                                       rdfs:label "incluye" .


###  http://example.org/ontologia#periodo_contiene_numero
<http://example.org/ontologia#periodo_contiene_numero> rdf:type owl:ObjectProperty ;
                                                       owl:inverseOf :numero_con_periodicidad ;
                                                       rdfs:domain <http://example.org/ontologia#Periodicidad> ;
                                                       rdfs:range <http://example.org/ontologia#Numero> ;
                                                       rdfs:comment "Define el vínculo entre una periodicidad y los números que se publicaron con esa frecuencia." ;
                                                       rdfs:label "periodo contiene número" .


###  http://example.org/ontologia#tiene_autor
<http://example.org/ontologia#tiene_autor> rdf:type owl:ObjectProperty ;
                                           owl:inverseOf :es_autor_de ;
                                           rdfs:domain <http://example.org/ontologia#Contenido> ;
                                           rdfs:range <http://example.org/ontologia#Autor> ;
                                           rdfs:comment "Define el vínculo de creación entre un contenido y su autor." ;
                                           rdfs:label "tiene autor" .


###  http://example.org/ontologia#tiene_paginacion
<http://example.org/ontologia#tiene_paginacion> rdf:type owl:ObjectProperty ;
                                                owl:inverseOf :es_paginacion_de ;
                                                rdfs:domain <http://example.org/ontologia#Contenido> ;
                                                rdfs:range <http://example.org/ontologia#Paginacion> ;
                                                rdfs:comment "Define cuál es la paginación de un contenido concreto." ;
                                                rdfs:label "tiene paginación" .


###  http://example.org/ontologia#tiene_periodicidad
<http://example.org/ontologia#tiene_periodicidad> rdf:type owl:ObjectProperty ;
                                                  owl:inverseOf :es_periodicidad_de ;
                                                  rdfs:domain <http://example.org/ontologia#Revista> ;
                                                  rdfs:range <http://example.org/ontologia#Periodicidad> ;
                                                  rdfs:comment "Define la periodicidad de una revista." ;
                                                  rdfs:label "tiene periodicidad" .


###  http://example.org/ontologia#viene_acompanado_de
<http://example.org/ontologia#viene_acompanado_de> rdf:type owl:ObjectProperty ;
                                                   owl:inverseOf :acompana_a ;
                                                   rdfs:domain <http://example.org/ontologia#Numero> ;
                                                   rdfs:range <http://example.org/ontologia#Suplemento> ;
                                                   rdfs:comment "Define el vínculo entre un número y su suplemento." ;
                                                   rdfs:label "viene acompañado de" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#acompana_a
:acompana_a rdf:type owl:ObjectProperty ;
            rdfs:domain <http://example.org/ontologia#Suplemento> ;
            rdfs:range <http://example.org/ontologia#Numero> ;
            rdfs:comment "Define el vínculo entre un suplemento y el número en el que se incluye." ;
            rdfs:label "acompaña a" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_autor_de
:es_autor_de rdf:type owl:ObjectProperty ;
             rdfs:domain <http://example.org/ontologia#Autor> ;
             rdfs:range <http://example.org/ontologia#Contenido> ;
             rdfs:comment "Define el vínculo de creación entre un autor y un contenido de su creación." ;
             rdfs:label "es autor de" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_cobertura_de
:es_cobertura_de rdf:type owl:ObjectProperty ;
                 owl:inverseOf :tiene_cobertura ;
                 rdfs:domain :Cobertura ;
                 rdfs:range <http://example.org/ontologia#Revista> ;
                 rdfs:comment "Define el vínculo entre la cobertura de números de una revista y la publicación." ;
                 rdfs:label "es cobertura de" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_dibujante_de
:es_dibujante_de rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :es_autor_de ;
                 owl:inverseOf :tiene_dibujante ;
                 rdfs:domain :dibujante ;
                 rdfs:range <http://example.org/ontologia#Contenido> ;
                 rdfs:comment "Define quién es el dibujante de un contenido." ;
                 rdfs:label "es dibujante de" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_guionista_de
:es_guionista_de rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :es_autor_de ;
                 owl:inverseOf :tiene_guionista ;
                 rdfs:domain :Guionista ;
                 rdfs:range <http://example.org/ontologia#Contenido> ;
                 rdfs:comment "Define quién es el guionista de un contenido." ;
                 rdfs:label "es guionista de" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_paginacion_de
:es_paginacion_de rdf:type owl:ObjectProperty ;
                  rdfs:domain <http://example.org/ontologia#Paginacion> ;
                  rdfs:range <http://example.org/ontologia#Contenido> ;
                  rdfs:comment "Define el vínculo entre un conjunto de páginas con el contenido que aparece en ellas." ;
                  rdfs:label "es paginación de" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#es_periodicidad_de
:es_periodicidad_de rdf:type owl:ObjectProperty ;
                    rdfs:domain <http://example.org/ontologia#Periodicidad> ;
                    rdfs:range <http://example.org/ontologia#Revista> ;
                    rdfs:comment "Define el vínculo entre una periodicidad y la revista a la que se aplica." ;
                    rdfs:label "es periodicidad de" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en
:esta_incluido_en rdf:type owl:ObjectProperty ;
                  rdfs:domain <http://example.org/ontologia#Contenido> ;
                  rdfs:range <http://example.org/ontologia#Numero> ;
                  rdfs:comment "Define el vínculo entre un contenido y el número en que está incluido." ;
                  rdfs:label "está incluido en" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#numero_con_periodicidad
:numero_con_periodicidad rdf:type owl:ObjectProperty ;
                         rdfs:domain <http://example.org/ontologia#Numero> ;
                         rdfs:range <http://example.org/ontologia#Periodicidad> ;
                         rdfs:comment "Define el vínculo entre un número y su periodicidad." ;
                         rdfs:label "número con periodicidad" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#numero_incluido
:numero_incluido rdf:type owl:ObjectProperty ;
                 owl:inverseOf :tiene_numero_incluido ;
                 rdfs:domain <http://example.org/ontologia#Numero> ;
                 rdfs:range :Cobertura ;
                 rdfs:comment "Define si un número está incluido en la colección de la revista." ;
                 rdfs:label "número incluido" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#numero_no_incluido
:numero_no_incluido rdf:type owl:ObjectProperty ;
                    owl:inverseOf :tiene_numero_no_incluido ;
                    rdfs:domain <http://example.org/ontologia#Numero> ;
                    rdfs:range :Cobertura ;
                    rdfs:comment "Define si un número no está incluido en la colección de la revista." ;
                    rdfs:label "número no incluido" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#representa_contenido
:representa_contenido rdf:type owl:ObjectProperty ;
                      rdfs:domain <http://example.org/ontologia#Imagen> ;
                      rdfs:range <http://example.org/ontologia#Contenido> ;
                      rdfs:comment "Define el vínculo entre un archivo de imagen y el contenido que aparece en él." ;
                      rdfs:label "representa contenido" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_cobertura
:tiene_cobertura rdf:type owl:ObjectProperty ;
                 rdfs:domain <http://example.org/ontologia#Revista> ;
                 rdfs:range :Cobertura ;
                 rdfs:comment "Define el vínculo entre una revista y la cobertura de números de la colección." ;
                 rdfs:label "tiene cobertura" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_dibujante
:tiene_dibujante rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf <http://example.org/ontologia#tiene_autor> ;
                 rdfs:domain <http://example.org/ontologia#Contenido> ;
                 rdfs:range :dibujante ;
                 rdfs:comment "Define el vínculo entre un contenido y su dibujante." ;
                 rdfs:label "tiene dibujante" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_guionista
:tiene_guionista rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf <http://example.org/ontologia#tiene_autor> ;
                 rdfs:domain <http://example.org/ontologia#Contenido> ;
                 rdfs:range :Guionista ;
                 rdfs:comment "Define el vínculo entre un contenido y su guionista." ;
                 rdfs:label "tiene guionista" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_numero_incluido
:tiene_numero_incluido rdf:type owl:ObjectProperty ;
                       rdfs:domain :Cobertura ;
                       rdfs:range <http://example.org/ontologia#Numero> ;
                       rdfs:comment "Define los números de la revista incluidos en la colección." ;
                       rdfs:label "tiene número incluido" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_numero_no_incluido
:tiene_numero_no_incluido rdf:type owl:ObjectProperty ;
                          rdfs:domain :Cobertura ;
                          rdfs:range <http://example.org/ontologia#Numero> ;
                          rdfs:comment "Define si en la colección de la revista hay algún número faltante." ;
                          rdfs:label "tiene número no incluido" .


#################################################################
#    Data properties
#################################################################

###  http://example.org/ontologia#descripcion
<http://example.org/ontologia#descripcion> rdf:type owl:DatatypeProperty ;
                                           rdfs:domain <http://example.org/ontologia#Contenido> ;
                                           rdfs:range xsd:string ;
                                           rdfs:comment "Descripción breve de un contenido." ;
                                           rdfs:label "descripción de contenido" .


###  http://example.org/ontologia#descripcion_revista
<http://example.org/ontologia#descripcion_revista> rdf:type owl:DatatypeProperty ;
                                                   rdfs:domain <http://example.org/ontologia#Revista> ;
                                                   rdfs:range xsd:string ;
                                                   rdfs:comment "Descripción breve de una publicación." ;
                                                   rdfs:label "descripción de revista" .


###  http://example.org/ontologia#nombre
<http://example.org/ontologia#nombre> rdf:type owl:DatatypeProperty ;
                                      rdfs:domain <http://example.org/ontologia#Autor> ;
                                      rdfs:range xsd:string ;
                                      rdfs:comment "Nombre propio de un autor." ;
                                      rdfs:label "nombre" .


###  http://example.org/ontologia#nombre_imagen
<http://example.org/ontologia#nombre_imagen> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <http://example.org/ontologia#Imagen> ;
                                             rdfs:range xsd:string ;
                                             rdfs:comment "Nombre del archivo de imagen." ;
                                             rdfs:label "nombre del archivo" .


###  http://example.org/ontologia#num_pagina
<http://example.org/ontologia#num_pagina> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain <http://example.org/ontologia#Imagen> ;
                                          rdfs:range xsd:integer ;
                                          rdfs:comment "Número de página que representa un archivo de imagen determinado." ;
                                          rdfs:label "número de página" .


###  http://example.org/ontologia#numero
<http://example.org/ontologia#numero> rdf:type owl:DatatypeProperty ;
                                      rdfs:domain <http://example.org/ontologia#Numero> ;
                                      rdfs:range xsd:integer ;
                                      rdfs:comment "Número que representa el orden de publicación de un número concreto." ;
                                      rdfs:label "número" .


###  http://example.org/ontologia#pagina_fin
<http://example.org/ontologia#pagina_fin> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain <http://example.org/ontologia#Paginacion> ;
                                          rdfs:range xsd:integer ;
                                          rdfs:comment "Página final de una paginación determinada." ;
                                          rdfs:label "página de fin" .


###  http://example.org/ontologia#pagina_inicio
<http://example.org/ontologia#pagina_inicio> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <http://example.org/ontologia#Paginacion> ;
                                             rdfs:range xsd:integer ;
                                             rdfs:comment "Página inicial de una paginación determinada." ;
                                             rdfs:label "página de inicio" .


###  http://example.org/ontologia#palabra_clave
<http://example.org/ontologia#palabra_clave> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <http://example.org/ontologia#Contenido> ;
                                             rdfs:range xsd:string ;
                                             rdfs:comment "Palabra clave que representa la temática de un contenido determinado." ;
                                             rdfs:label "palabra clave" .


###  http://example.org/ontologia#pseudonimo
<http://example.org/ontologia#pseudonimo> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain <http://example.org/ontologia#Autor> ;
                                          rdfs:range xsd:string ;
                                          rdfs:comment "Pseudónimo de un autor determinado." ;
                                          rdfs:label "pseudónimo" .


###  http://example.org/ontologia#tipo_contenido
<http://example.org/ontologia#tipo_contenido> rdf:type owl:DatatypeProperty ;
                                              rdfs:domain <http://example.org/ontologia#Contenido> ;
                                              rdfs:range xsd:string ;
                                              rdfs:comment "Tipología de contenido: Cómic,  Ilustración, Texto, Texto con ilustración (texto acompañado de un dibujo), Texto con imagen (texto acompañado de imagen fotocopiada), Pasatiempo (juego, puzle, etc.), Índice, Editorial, Portada, Contraportada." ;
                                              rdfs:label "tipo de contenido" .


###  http://example.org/ontologia#tipo_numero
<http://example.org/ontologia#tipo_numero> rdf:type owl:DatatypeProperty ;
                                           rdfs:domain <http://example.org/ontologia#Numero> ;
                                           rdfs:range xsd:string ;
                                           rdfs:comment "Tipología de número. Por ejemplo, número ordinario, número especial, número recopilatorio." ;
                                           rdfs:label "tipo de número" .


###  http://example.org/ontologia#tipo_periodo
<http://example.org/ontologia#tipo_periodo> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <http://example.org/ontologia#Periodicidad> ;
                                            rdfs:range xsd:string ;
                                            rdfs:comment "Tipo de periodicidad: Mensual, Semestral, Anual, Bianual, etc." ;
                                            rdfs:label "tipo de periodicidad" .


###  http://example.org/ontologia#tipo_suplemento
<http://example.org/ontologia#tipo_suplemento> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <http://example.org/ontologia#Suplemento> ;
                                               rdfs:range xsd:string ;
                                               rdfs:comment "Tipología de suplemento: Suplemento, Periódico, Material promocional, etc...." ;
                                               rdfs:label "tipo de suplemento" .


###  http://example.org/ontologia#titulo_alternativo
<http://example.org/ontologia#titulo_alternativo> rdf:type owl:DatatypeProperty ;
                                                  rdfs:domain <http://example.org/ontologia#Revista> ;
                                                  rdfs:range xsd:string ;
                                                  rdfs:comment "Título alternativo de una revista." ;
                                                  rdfs:label "título alternativo" .


###  http://example.org/ontologia#titulo_contenido
<http://example.org/ontologia#titulo_contenido> rdf:type owl:DatatypeProperty ;
                                                rdfs:domain <http://example.org/ontologia#Contenido> ;
                                                rdfs:range xsd:string ;
                                                rdfs:comment "Título del contenido que se está describiendo." ;
                                                rdfs:label "título de contenido" .


###  http://example.org/ontologia#titulo_revista
<http://example.org/ontologia#titulo_revista> rdf:type owl:DatatypeProperty ;
                                              rdfs:domain <http://example.org/ontologia#Revista> ;
                                              rdfs:range xsd:string ;
                                              rdfs:comment "Título de la revista." ;
                                              rdfs:label "título de revista" .


###  http://example.org/ontologia#titulo_suplemento
<http://example.org/ontologia#titulo_suplemento> rdf:type owl:DatatypeProperty ;
                                                 rdfs:domain <http://example.org/ontologia#Suplemento> ;
                                                 rdfs:range xsd:string ;
                                                 rdfs:comment "Título del suplemento que acompaña a un número determinado." ;
                                                 rdfs:label "título de suplemento" .


###  http://example.org/ontologia#total_paginas
<http://example.org/ontologia#total_paginas> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <http://example.org/ontologia#Numero> ;
                                             rdfs:range xsd:integer ;
                                             rdfs:comment "Total de páginas de un número o suplemento." ;
                                             rdfs:label "total de páginas" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#anio_publicacion
:anio_publicacion rdf:type owl:DatatypeProperty ;
                  rdfs:domain <http://example.org/ontologia#Numero> ;
                  rdfs:range xsd:gYear ;
                  rdfs:comment "Año de publicación de un número." ;
                  rdfs:label "año de publicación" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#apellidos
:apellidos rdf:type owl:DatatypeProperty ;
           rdfs:domain <http://example.org/ontologia#Autor> ;
           rdfs:range xsd:string ;
           rdfs:comment "Apellidos del autor." ;
           rdfs:label "apellidos" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#descontinuada
:descontinuada rdf:type owl:DatatypeProperty ;
               rdfs:domain <http://example.org/ontologia#Revista> ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Identifica si la revista ha dejado de editarse y circular." ;
               rdfs:label "descontinuada" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#precio
:precio rdf:type owl:DatatypeProperty ;
        rdfs:domain <http://example.org/ontologia#Numero> ;
        rdfs:range xsd:string ;
        rdfs:comment "Precio del número de una revista." ;
        rdfs:label "precio" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#subtitulo_revista
:subtitulo_revista rdf:type owl:DatatypeProperty ;
                   rdfs:domain <http://example.org/ontologia#Revista> ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Subtítulo de una revista." ;
                   rdfs:label "subtítulo" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#url_imagen
:url_imagen rdf:type owl:DatatypeProperty ;
            rdfs:domain <http://example.org/ontologia#Imagen> ;
            rdfs:range xsd:string ;
            rdfs:comment "URL donde se aloja la imagen." ;
            rdfs:label "url de imagen" .


#################################################################
#    Classes
#################################################################

###  http://example.org/ontologia#Autor
<http://example.org/ontologia#Autor> rdf:type owl:Class ;
                                     rdfs:comment "Autor o autora de una pieza de contenido de la publicación." ;
                                     rdfs:label "Autor" .


###  http://example.org/ontologia#Contenido
<http://example.org/ontologia#Contenido> rdf:type owl:Class ;
                                         rdfs:comment "Cada una de las piezas de contenido de un número o suplemento." ;
                                         rdfs:label "Contenido" .


###  http://example.org/ontologia#Imagen
<http://example.org/ontologia#Imagen> rdf:type owl:Class ;
                                      rdfs:comment "Imagen o imágenes vinculadas a la pieza de contenido." ;
                                      rdfs:label "Imagen" .


###  http://example.org/ontologia#Numero
<http://example.org/ontologia#Numero> rdf:type owl:Class ;
                                      rdfs:comment "Cada uno de los números que componen una revista." ;
                                      rdfs:label "Número" .


###  http://example.org/ontologia#Paginacion
<http://example.org/ontologia#Paginacion> rdf:type owl:Class ;
                                          rdfs:comment "Páginas que abarca una pieza de contenido." ;
                                          rdfs:label "Paginación" .


###  http://example.org/ontologia#Periodicidad
<http://example.org/ontologia#Periodicidad> rdf:type owl:Class ;
                                            rdfs:comment "Frecuencia de publicación." ;
                                            rdfs:label "Periodicidad" .


###  http://example.org/ontologia#Revista
<http://example.org/ontologia#Revista> rdf:type owl:Class ;
                                       rdfs:comment "Publicación compuesta de diferentes números que contienen piezas de contenido." ;
                                       rdfs:label "Revista" .


###  http://example.org/ontologia#Suplemento
<http://example.org/ontologia#Suplemento> rdf:type owl:Class ;
                                          rdfs:subClassOf <http://example.org/ontologia#Numero> ;
                                          rdfs:comment "Publicación aneja e independiente de un número ordinario." ;
                                          rdfs:label "Suplemento" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Cobertura
:Cobertura rdf:type owl:Class ;
           rdfs:comment "Números contenidos en la colección, incluyendo los faltantes." ;
           rdfs:label "Cobertura" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Guionista
:Guionista rdf:type owl:Class ;
           rdfs:subClassOf <http://example.org/ontologia#Autor> ;
           rdfs:comment "Guionista de una pieza de contenido. Suele colaborar con un dibujante." ;
           rdfs:label "Guionista" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional
:Material_promocional rdf:type owl:Class ;
                      rdfs:subClassOf <http://example.org/ontologia#Contenido> ;
                      rdfs:comment "Materiales y publicaciones adicionales de carácter promocional." ;
                      rdfs:label "Material promocional" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#dibujante
:dibujante rdf:type owl:Class ;
           rdfs:subClassOf <http://example.org/ontologia#Autor> ;
           rdfs:comment "Dibujante de una pieza de contenido. Suele colaborar con un guionista." ;
           rdfs:label "Dibujante" .


