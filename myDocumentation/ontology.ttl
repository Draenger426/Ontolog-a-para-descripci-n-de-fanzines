         <http://example.org/ontologia#palabra_clave> "Juegos" ;
         <http://example.org/ontologia#tipo_contenido> "Pasatiempos" ;
         <http://example.org/ontologia#titulo_contenido> "¿Has encontrado a tu profesor? Mira aquí también" ;
         rdfs:label "Contenido #0636" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0701
:con0701 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
