###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#folleto001
:folleto001 rdf:type owl:NamedIndividual ,
                     :Material_promocional ;
            <http://example.org/ontologia#aparece_en_imagen> :img9301 ,
                                                             :img9302 ,
                                                             :img9303 ,
                                                             :img9304 ,
                                                             :img9305 ,
                                                             :img9306 ,
                                                             :img9307 ,
                                                             :img9308 ,
                                                             :img9309 ,
                                                             :img9310 ,
                                                             :img9311 ,
                                                             :img9313 ;
            <http://example.org/ontologia#descripcion> """Folleto que informa sobre la revista Radikal Al Kilo del año 93. En este folleto podemos ver que tiene cuatro contenidos:
1. Aventura en la facurtá de siensiah
2. ¿Cómo se hace Radikal Al Kilo?
3. ¿Qué opinan de R.A.K.?
4. ¿Qué motivos puedo tener para participar en Radical?
A parte, tenemos una portada de una mujer semidesnuda y un esqueleto, dibujado por Fernando S.P.""" ;
            <http://example.org/ontologia#tipo_contenido> "Texto" ;
            rdfs:label "Folletó Informativo 93" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#folleto002
:folleto002 rdf:type owl:NamedIndividual ,
                     :Material_promocional ;
            <http://example.org/ontologia#aparece_en_imagen> :img9401 ,
                                                             :img9402 ,
                                                             :img9403 ,
                                                             :img9404 ,
                                                             :img9405 ,
                                                             :img9406 ,
                                                             :img9407 ,
                                                             :img9408 ;
            <http://example.org/ontologia#descripcion> """Folleto Informativo de la revista Radikal Al Kilo lanzado en el curso 94-95. En el folleto viene incluido los siguientes contenidos:
1. Matrículas
2. ¿Sabes dónde está...?
3. Uniforme y armamento del perfecto alumno de combate.
4. Suspensator, dibujado por Antonio Jesús Torres Gil.
5. Los exámenes
6. Orgasmo de una noche de otoño.
A parte, tenemos una portada y contraportada dibujadas por C.M.M., donde podemos ver a un buitre de dos cabezas parodiando el escudo de la Universidad de Granada.""" ;
            <http://example.org/ontologia#tipo_contenido> "Cómic" ,
                                                          "Texto con imagenes" ;
            rdfs:label "Folletó Informativo 94" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#folleto003
:folleto003 rdf:type owl:NamedIndividual ,
                     :Material_promocional ;
            <http://example.org/ontologia#aparece_en_imagen> :img9501 ,
                                                             :img9502 ,
                                                             :img9503 ,
                                                             :img_folleto9504 ;
            <http://example.org/ontologia#descripcion> """Folleto Informativo de la revista Radikal Al Kilo del curso 95-96. En él vienen dos contenidos:
1. Colabora con RAK
2. ¿Qué opinan de R.A.K.?, que ya apareció en el folletó informativo del año 93.
A parte, viene con la misma portada del folleto anterior, del año 94, y la contraportada es una foto de una mujer que viene firmada como Claudia""" ;
            <http://example.org/ontologia#tipo_contenido> "Cómic" ,
                                                          "Texto con imágenes" ;
            rdfs:label "Folletó Informativo 95" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#folleto004
:folleto004 rdf:type owl:NamedIndividual ,
                     :Material_promocional ;
            <http://example.org/ontologia#aparece_en_imagen> :img9601 ,
                                                             :img9602 ;
            <http://example.org/ontologia#descripcion> "Folleto Informativo con la presentación de RAK. Su portada es el águila del escudo de la UGR cocinado. Mientras, la contraportada es una croquis de la facultad." ;
            <http://example.org/ontologia#tipo_contenido> "Texto con imágenes" ;
            rdfs:label "Folletó Informativo 96" .


