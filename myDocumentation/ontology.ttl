         <http://example.org/ontologia#tipo_contenido> "Cómic" ;
         <http://example.org/ontologia#titulo_contenido> "El submarino" ;
         rdfs:label "Contenido #0618" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0619
:con0619 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0653 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0619 ;
         :esta_incluido_en :num06 ;
         <http://example.org/ontologia#descripcion> "Página promocional con caricatura que asemeja un directivo “Sr. Financiación” con un demonio, que aparece leyendo el fanzine." ;
         <http://example.org/ontologia#palabra_clave> "Publicidad" ;
         <http://example.org/ontologia#tipo_contenido> "Parodia publicitaria" ;
         rdfs:label "Contenido #0619" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0620
:con0620 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0654 ,
                                                          :img0655 ,
                                                          :img0656 ,
                                                          :img0657 ,
                                                          :img0658 ,
                                                          :img0659 ,
                                                          :img0660 ,
                                                          :img0661 ;
         <http://example.org/ontologia#tiene_autor> :pedro_gadicto ;
         <http://example.org/ontologia#tiene_paginacion> :pag0620 ;
         :esta_incluido_en :num06 ;
         <http://example.org/ontologia#descripcion> "Crónica detallada sobre la proyección del vídeo de Radical al Kilo en el Aula Magna. Relata las dificultades técnicas, la falta de presupuesto y agradece la colaboración del Departamento de Bellas Artes (por la cámara) y de varios estudiantes y bedeles. Menciona la proyección de películas de Woody Allen y Mel Brooks como acompañamiento." ;
         <http://example.org/ontologia#palabra_clave> "Relatos" ;
         <http://example.org/ontologia#tipo_contenido> "Texto" ;
         <http://example.org/ontologia#titulo_contenido> "Un fancine y su sueño" ;
         rdfs:label "Contenido #0620" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0621
:con0621 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
