                              <http://example.org/ontologia#Contenido> ;
                     <http://example.org/ontologia#aparece_en_imagen> :img1040 ;
                     <http://example.org/ontologia#tiene_paginacion> :pag_seccion1002 ;
                     :esta_incluido_en :num10 ;
                     <http://example.org/ontologia#descripcion> "Dibujo de una pareja enamorada abrazándose. Esta portada da entrada a la sección de amor del número 10 de RAK." ;
                     <http://example.org/ontologia#palabra_clave> "Amor" ,
                                                                  "Romance" ;
                     <http://example.org/ontologia#tipo_contenido> "Portada" ;
                     rdfs:label "Portada #seccion1002" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#portada_sti_01
:portada_sti_01 rdf:type owl:NamedIndividual ,
                         <http://example.org/ontologia#Contenido> ;
                <http://example.org/ontologia#aparece_en_imagen> :img0101_sti ;
                :esta_incluido_en :radikal_sstilo_01 ;
                <http://example.org/ontologia#descripcion> "Dibujo de un maestra de ceremonias de un cirxo. El dibujo es un calco de otra obra de Milo Manara." ;
                <http://example.org/ontologia#tipo_contenido> "Portada" ;
                :nota "La portada de Radikal Sstilo sirve de contraportada del número 8 de Radikal Al Kilo. Se aprecia que está en formato vertical inverso." ;
                rdfs:label "Portada #sti01" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#portadasstilo00
:portadasstilo00 rdf:type owl:NamedIndividual ,
                          <http://example.org/ontologia#Contenido> ;
