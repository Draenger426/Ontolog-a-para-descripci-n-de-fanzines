               <http://example.org/ontologia#aparece_en_imagen> :img_calendario0301 ,
                                                                :img_calendario0302 ;
               <http://example.org/ontologia#descripcion> "Calendario del año 1999. Viene acompañado de un dibujo de un señor mayor de vacaciones celebrando que por fin acabó la universidad." ;
               <http://example.org/ontologia#tipo_contenido> "Calendario" ;
