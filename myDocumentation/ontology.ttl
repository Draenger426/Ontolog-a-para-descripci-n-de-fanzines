###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#marcapaginas_navidad
:marcapaginas_navidad rdf:type owl:NamedIndividual ,
                               :Material_promocional ;
                      <http://example.org/ontologia#aparece_en_imagen> :img_navidad01 ,
                                                                       :img_navidad02 ,
                                                                       :img_navidad03 ,
                                                                       :img_navidad04 ,
                                                                       :img_navidad05 ,
                                                                       :img_navidad06 ;
                      <http://example.org/ontologia#descripcion> "Colección de marcapáginas satíricos editados en 1995 bajo la serie irónica \"I Love...\", ilustrados por AJTG (Antonio Jesús Torres Gil). Las viñetas cargan con humor negro contra la vida universitaria y la actualidad: desde la ruina económica estudiantil por los \"Precios Públicos\" y la crueldad de los \"Catedráticos\" y \"Profesores Huesos\" (representados como cerdos o puertas aplastantes), hasta el deseo de dinamitar la Facultad o la crítica a las pruebas nucleares francesas en Mururoa mediante un esqueleto hawaiano." ;
                      <http://example.org/ontologia#tipo_contenido> "Marcapáginas" ;
                      rdfs:label "Marcapáginas de Navidad" .


