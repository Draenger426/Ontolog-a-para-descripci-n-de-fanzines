###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#calendario04
:calendario04 rdf:type owl:NamedIndividual ,
                       :Material_promocional ;
              <http://example.org/ontologia#aparece_en_imagen> :img_calendario0401 ,
                                                               :img_calendario0402 ;
              <http://example.org/ontologia#descripcion> "Calendario de bolsillo de 1997 publicitario del \"Café Bar LAS TORRES\", un establecimiento clásico situado en la calle Trucha del barrio de La Chana (Granada), regentado por José Puertas Díaz y famoso por sus \"tapas variadas y caracoles\". El lote se completa con una tarjeta satírica sobre gestión laboral (\"Escoja usted\"), que ilustra el clásico \"triángulo de la calidad\" obligando al cliente a elegir solo dos opciones entre un trabajo \"Barato, Rápido y Bueno\", advirtiendo que la combinación de las tres es imposible." ;
              <http://example.org/ontologia#tipo_contenido> "Calendario" ;
              rdfs:label "Calendario #04" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#certamen_humor
:certamen_humor rdf:type owl:NamedIndividual ,
                         :Material_promocional ;
                <http://example.org/ontologia#aparece_en_imagen> :img_certamen ;
                :esta_incluido_en :num12 ;
                <http://example.org/ontologia#descripcion> "Cartel informativo del \"I CERTAMEN DE HUMOR SAN ALBERTO MAGNO\", un concurso organizado por la Asociación Cultural Radical Al Kilo que abarca categorías de redacción, fotografía y humor gráfico. La ilustración central muestra a un personaje ambicioso gritando \"¡LO QUIERO TODOO!\" desde un despacho caótico lleno de humo y objetos extraños (incluyendo un pollo colgado), mientras un operario termina de pegar el cartel en una valla publicitaria. El evento cuenta con el patrocinio institucional del Vicerrectorado de Estudiantes y la colaboración de la Casa de Porras y la Facultad de Ciencias, dirigiendo a los interesados a la Sala de Alumnos o al apartado de correos 1275 de Granada." ;
                <http://example.org/ontologia#tipo_contenido> "Texto con dibujo" ;
                <http://example.org/ontologia#titulo_contenido> "I CERTAMEN DE HUMOR SAN ALBERTO MAGNO" ;
                rdfs:label "I Certamen de Humor" .


