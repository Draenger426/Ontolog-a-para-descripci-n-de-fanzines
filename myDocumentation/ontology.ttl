                  <http://example.org/ontologia#Contenido> ;
         owl:sameAs :con1301 ;
         <http://example.org/ontologia#aparece_en_imagen> :img0235 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0223 ;
