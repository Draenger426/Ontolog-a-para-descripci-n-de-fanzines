###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0101
:con0101 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0104 ,
                                                          :img0105 ,
                                                          :img0106 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0101 ;
         :esta_incluido_en :num01 ;
         :tiene_dibujante :antonio_cadenas ;
         :tiene_guionista :antonio_cadenas ;
         <http://example.org/ontologia#descripcion> "Cómic que narra el despertar de un difunto (fallecido entre 1800-1820) en un cementerio ante la aparición de una figura celestial que le ofrece la resurrección. Sin embargo, tras echar un vistazo a la realidad moderna proyectada en una tira de película (guerras, contaminación, niños hambrientos, el poder del dinero y el conflicto geopolítico EEUU-URSS), el protagonista rechaza la oferta inmediatamente y se encierra de nuevo en su tumba sentenciando: \"¡Me lo pensé una sola vez!\"." ;
         <http://example.org/ontologia#palabra_clave> "Crítica social" ,
                                                      "Humor negro" ;
         <http://example.org/ontologia#tipo_contenido> "Cómic" ;
         <http://example.org/ontologia#titulo_contenido> "El Muerto" ;
         rdfs:label "Contenido #0101" .


