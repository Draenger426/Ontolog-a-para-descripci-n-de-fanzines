         owl:sameAs :con1312 ;
         <http://example.org/ontologia#aparece_en_imagen> :img0458 ,
                                                          :img0459 ,
                                                          :img0460 ,
                                                          :img0461 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0424 ;
         :esta_incluido_en :num04 ;
         rdfs:label "Contenido #0424" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con1312

###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0425
:con0425 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0462 ,
                                                          :img0463 ;
         <http://example.org/ontologia#tiene_autor> :pedro_gadicto ;
         <http://example.org/ontologia#tiene_paginacion> :pag0425 ;
         :esta_incluido_en :num04 ;
         <http://example.org/ontologia#descripcion> "Reseña musical sobre el álbum \"Everything\" de The Bangles, analizando temas como \"In your room\" y comparando su estilo \"Falk-rock\" (sic) con la década de los 60. El bloque cierra con un anuncio satírico de la \"ACADEMIA CHORONTOLOGICA DE MASSACHURSET\", ilustrado con un atraco a navaja, que ofrece cursos de delincuencia (\"dinero fácil\") y \"rápida colocación\" en un sector en expansión." ;
         <http://example.org/ontologia#palabra_clave> "Música" ,
                                                      "Reseñas" ;
         <http://example.org/ontologia#tipo_contenido> "Texto" ;
         <http://example.org/ontologia#titulo_contenido> "Música: The Bangles" ;
         rdfs:label "Contenido #0425" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0426
:con0426 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0464 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0426 ;
         :esta_incluido_en :num04 ;
         <http://example.org/ontologia#descripcion> "Ilustración que presenta a la mascota oficial de \"Radikal-al-Kilo (El Fanzine Cuántico)\", un personaje surrealista que sostiene una hélice y un objeto humeante bajo un gran número 5. El texto manuscrito bromea con la generosidad de los autores (\"Mirad que somos buenos\") regalando este diseño además del próximo número." ;
         <http://example.org/ontologia#tipo_contenido> "Ilustración" ;
         rdfs:label "Contenido #0426" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0427
:con0427 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0465 ,
                                                          :img0466 ,
                                                          :img0467 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0427 ;
         :esta_incluido_en :num04 ;
         <http://example.org/ontologia#descripcion> "Reportaje  que ofrece una guía de lectura clasificada en tres vertientes: la reedición de clásicos como Mickey Mouse (por su 60º aniversario) o Little Nemo; la reseña de álbumes recientes de autores españoles como Carlos Giménez (Los Profesionales), Bernet (Torpedo 1936) y Jhonny Roqueta; y un análisis de mercado para no iniciados sobre las revistas Cairo, Cimoc, Totem, Zona 84 y El Víbora, todo ello ilustrado con viñetas de las obras citadas." ;
         <http://example.org/ontologia#palabra_clave> "Cómics" ,
                                                      "Reseñas" ;
         <http://example.org/ontologia#tipo_contenido> "Texto con ilustración" ;
         <http://example.org/ontologia#titulo_contenido> "Cómics" ;
         rdfs:label "Contenido #0427" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0428
