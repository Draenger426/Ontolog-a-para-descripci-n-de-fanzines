             <http://example.org/ontologia#tiene_paginacion> :pag0101_sti ;
             :esta_incluido_en :radikal_sstilo_01 ;
             <http://example.org/ontologia#descripcion> "Preguntas tipo test para saber si eres un santo, con preguntas irónicas y retóricas sobre la biblia, los pecados, etc." ;
             <http://example.org/ontologia#palabra_clave> "Pasatiempos" ;
             <http://example.org/ontologia#tipo_contenido> "Texto" ;
             <http://example.org/ontologia#titulo_contenido> "Test: ¿Eres un santo/a?" ;
             rdfs:label "Contenido #sti0101" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0102
:con0102 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0107 ,
                                                          :img0108 ;
         <http://example.org/ontologia#tiene_autor> :j_rodriguez ;
         <http://example.org/ontologia#tiene_paginacion> :pag0102 ;
         :esta_incluido_en :num01 ;
         <http://example.org/ontologia#descripcion> "Historia que narra en primera persona un viaje al Rally Safari en Nairobi (Kenia). El protagonista describe con humor sus desventuras al recibir un inadecuado Cadillac descapotable rosa de los años 60 en lugar de un todoterreno, vehículo con el que seduce a una misteriosa motorista en la sabana; la historia concluye con un salto temporal pesimista, donde el autor lamenta su aburrida vida doméstica actual (\"casado, con un niño y un abominable vehículo familiar\") frente a la libertad perdida de aquella aventura." ;
         <http://example.org/ontologia#palabra_clave> "Humor negro" ,
                                                      "Relatos" ;
         <http://example.org/ontologia#tipo_contenido> "Texto" ;
         <http://example.org/ontologia#titulo_contenido> "Don Quixote" ;
         rdfs:label "Contenido #0102" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0102_sti
:con0102_sti rdf:type owl:NamedIndividual ,
                      <http://example.org/ontologia#Contenido> ;
             <http://example.org/ontologia#aparece_en_imagen> :img0108_sti ;
             <http://example.org/ontologia#tiene_autor> :pedro_gadicto ;
             <http://example.org/ontologia#tiene_paginacion> :pag0102_sti ;
             :esta_incluido_en :radikal_sstilo_01 ;
             <http://example.org/ontologia#descripcion> "Pedro Gadicto engaña con este artículo a la gente que quisiera conocer la respuesta de un concurso en un número anterior, nombrando a dos personas que fueron los únicos en contestar." ;
             <http://example.org/ontologia#palabra_clave> "Pasatiempos" ;
             <http://example.org/ontologia#tipo_contenido> "Texto" ;
             <http://example.org/ontologia#titulo_contenido> "Las doce pesas..." ;
             rdfs:label "Contenido #sti0102" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0103
:con0103 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0109 ;
         <http://example.org/ontologia#tiene_paginacion> :pag0103 ;
         :esta_incluido_en :num01 ;
         <http://example.org/ontologia#descripcion> "Retrata la apatía vital de un estudiante deprimido que hace todo por inercia: estudia Biológicas aunque quiere ser bombero, sale de marcha aunque se aburre y escucha a Modern Talking aunque le duele la cabeza. La historieta concluye definiendo científicamente la inercia como la resistencia al cambio de estado, aplicándola irónicamente a su propia vida vacía." ;
         <http://example.org/ontologia#palabra_clave> "Crítica social" ,
                                                      "Estudiantes" ;
         <http://example.org/ontologia#tipo_contenido> "Cómic" ;
         <http://example.org/ontologia#titulo_contenido> "Inercia" ;
         rdfs:label "Contenido #0103" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0103_sti
:con0103_sti rdf:type owl:NamedIndividual ,
                      <http://example.org/ontologia#Contenido> ;
             owl:sameAs :con1344 ;
             <http://example.org/ontologia#aparece_en_imagen> :img0109_sti ,
                                                              :img0110_sti ;
             <http://example.org/ontologia#tiene_paginacion> :pag0103_sti ;
             :esta_incluido_en :radikal_sstilo_01 ;
             :tiene_dibujante :pedro_gadicto ;
             :tiene_guionista :pedro_gadicto ;
             <http://example.org/ontologia#descripcion> "Publicidad que pregunta lo que quieres ser de mayor. Podemos ver un dibujo de una niña durmiendo, y otro de una mujer haciendo una pose erótica." ;
             <http://example.org/ontologia#tipo_contenido> "Pardodia publicitaria" ;
             rdfs:label "Contenido #sti0103" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con1344

###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0104
:con0104 rdf:type owl:NamedIndividual ,
                  <http://example.org/ontologia#Contenido> ;
         <http://example.org/ontologia#aparece_en_imagen> :img0110 ;
         <http://example.org/ontologia#tiene_autor> :a_saavedra ;
         <http://example.org/ontologia#tiene_paginacion> :pag0104 ;
         :esta_incluido_en :num01 ;
         <http://example.org/ontologia#descripcion> "Exclusiva con el bíblico Noé, encontrado de juerga en un chiringuito, quien confiesa que el Diluvio Universal fue un invento y que construyó el Arca únicamente para \"irse de marcha\" con los colegas por Marbella y la calle Pedro Antonio. El patriarca se muestra decepcionado con el ecologismo (preguntando si es \"alguna droga\") y se queja de la borrachera de los animales a bordo, todo ello maquetado con una estética de fanzine punk con letras recortadas tipo anónimo bajo el sello \"AHÍ QUEDA ESO\"." ;
         <http://example.org/ontologia#palabra_clave> "Parodia" ,
                                                      "Religión" ;
         <http://example.org/ontologia#tipo_contenido> "Texto" ;
         <http://example.org/ontologia#titulo_contenido> "¡Qué NOE-stas AL LORO, COLEGA!" ;
         rdfs:label "Contenido #0104" .


###  http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0104_sti
:con0104_sti rdf:type owl:NamedIndividual ,
                      <http://example.org/ontologia#Contenido> ;
             <http://example.org/ontologia#aparece_en_imagen> :img0111_sti ,
                                                              :img0112_sti ,
                                                              :img0113_sti ,
                                                              :img0114_sti ;
             <http://example.org/ontologia#tiene_paginacion> :pag0104_sti ;
             :esta_incluido_en :radikal_sstilo_01 ;
             <http://example.org/ontologia#descripcion> "Consultorio algo obsceno entre una doctora sexóloga y su paciente a través, simulando la conversación a través de cartas que le llega a la doctora." ;
             <http://example.org/ontologia#palabra_clave> "Amor" ,
                                                          "Humor verde" ;
             <http://example.org/ontologia#tipo_contenido> "Texto" ;
             <http://example.org/ontologia#titulo_contenido> "Consultorio sexológico" ;
             rdfs:label "Contenido #sti0104" .


