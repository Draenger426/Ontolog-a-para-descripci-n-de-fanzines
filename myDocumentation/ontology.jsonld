  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Cuestionario de 30 preguntas cargadas de referencias a la cultura pop de finales de los 80, mencionando grupos como Hombres G, Gabinete Caligari o Duncan Dhu, programas de TV como \"El Precio Justo\" o \"Luz de Luna\" (citando a Maddie y David), y figuras eróticas o políticas como la Cicciolina."
  } ],
