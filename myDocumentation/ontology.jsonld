}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#marcapaginas_navidad",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_navidad01"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_navidad02"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_navidad03"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_navidad04"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_navidad05"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_navidad06"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Colección de marcapáginas satíricos editados en 1995 bajo la serie irónica \"I Love...\", ilustrados por AJTG (Antonio Jesús Torres Gil). Las viñetas cargan con humor negro contra la vida universitaria y la actualidad: desde la ruina económica estudiantil por los \"Precios Públicos\" y la crueldad de los \"Catedráticos\" y \"Profesores Huesos\" (representados como cerdos o puertas aplastantes), hasta el deseo de dinamitar la Facultad o la crítica a las pruebas nucleares francesas en Mururoa mediante un esqueleto hawaiano."
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Marcapáginas"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Marcapáginas de Navidad"
  } ]
