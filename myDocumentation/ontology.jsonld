  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Ilustración que representa un enérgico concierto de punk-rock protagonizado por una banda mixta y un público de crestas afiladas. La composición sirve como vehículo para una demanda estudiantil explícita plasmada en dos grandes pancartas: \"EXIGIMOS MAS ACTOS CULTURALES EN LA FACULTAD\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Crítica social"
  }, {
    "@value" : "Cultura Punk"
  } ],
