}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#acta__fundacional",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta01"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta02"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta03"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta04"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta05"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta06"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta07"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta08"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta09"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_acta10"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Documentación legal administrativa que formaliza la constitución de la Asociación Cultural \"RADICAL AL KILO\" (R.A.K.), elevando el fanzine a entidad oficial registrada en la Junta de Andalucía con el número 1.944. El conjunto incluye el Acta Fundacional firmada en la Facultad de Ciencias el 28 de diciembre de 1991 (coincidiendo irónicamente con el Día de los Santos Inocentes) por siete socios fundadores, entre ellos Antonio Javier Muñoz Benítez y Bruno José Jiménez Guisado. Se adjuntan los Estatutos aprobados en 1992, que establecen el carácter no lucrativo de la asociación, fijan su patrimonio inicial en 10.000 pesetas, definen la revista como su \"órgano de expresión\" principal y protegen legalmente el uso exclusivo de las siglas R.A.K. frente a terceros."
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Acta Fundacional de la Asociación Cultural 'Radikal al Kilo'"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Acta Fundacional de la Asociación Cultural Radical al Kilo"
  } ]
