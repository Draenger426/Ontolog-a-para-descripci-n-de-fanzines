}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#periodico_abril95",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_periodico9501"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_periodico9502"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_periodico9503"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Reportaje especial publicado en el suplemento \"La Uni\" del diario IDEAL (25 de abril de 1995), que dedica su página 7 a analizar la trayectoria del grupo bajo el titular \"Humor al peso\". El artículo, ilustrado con una fotografía de los miembros (Pedro Gadicto, Fernando Nante y Moha Medo), destaca la madurez de la asociación al organizar las III Jornadas Culturales \"en perfecta seriedad\" (con teatro de Brecht y cine de Tarantino) y repasa su historia desde la fundación en 1987 hasta su legalización oficial el Día de los Santos Inocentes de 1991, mencionando a su mascota extraterrestre Glork. El lote se completa con la portada del suplemento y una crónica sobre la CAI (Coordinadora Andaluza Interuniversitaria) y la \"guerra de las tasas\", que contextualiza el clima de protesta estudiantil de aquellos años."
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto con imágenes"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Periódico Abril 1995"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#periodico_mayo94",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_periodico9401"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_periodico9402"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_periodico9403"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_periodico9404"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Recortes de prensa del diario IDEAL (sección Universidad, 10 de mayo de 1994) que documentan la repercusión oficial de las actividades del grupo. El artículo central, titulado \"Docto guateque\", cubre la clausura de la II Semana Cultural de Radical Al Kilo en la Casa de Porras, destacando el ambiente lúdico con \"calderos de sangría\" y patatas fritas, actuaciones de magia y música andina (Amaru Churay), y declaraciones del socio Fernando Santamaría. La página comparte espacio con un reportaje sobre fútbol para invidentes (\"Ver para creer\") y se complementa con una segunda hoja dedicada a una exposición permanente de esculturas griegas en la Facultad de Filosofía y Letras (\"Es cultura, es griega\")."
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto con imágenes"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Periódico Mayo 1994"
  } ]
