}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0116",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0129"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0130"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Sección de acertijos físicos y lógicos diseñados para desafiar la intuición del lector. Los problemas plantean situaciones curiosas sobre mecánica, óptica y termodinámica —como si un hombre invisible podría ver, por qué la arena mojada parece más oscura, el equilibrio corporal al intentar tocarse los pies contra una pared o la capacidad real de dos cafeteras con distinta forma—, ofreciendo explicaciones técnicas detalladas en la página posterior para resolver cada paradoja."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Ciencia"
  }, {
    "@value" : "Física"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0116"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "A cuestiones científicas, soluciones científicas"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"
  } ],
