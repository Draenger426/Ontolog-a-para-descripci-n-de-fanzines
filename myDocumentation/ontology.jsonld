}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#editorial01",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0102"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Tablón de anuncios policial de \"TOP SECRET\" y \"CASOS PERDIDOS\", donde los miembros del equipo son presentados como delincuentes en una lista de \"SE BUSCAN\" y \"ENEMIGOS PÚBLICOS\". Cada redactor tiene una ficha con caricatura, alias y delitos absurdos: M. Talavera (Alias Fusta) por \"extorsión al obrero\", A. Vargas (Alias Retoque) por pintar bigotes en carteles, A. Martínez (Alias Cutre) por prácticas de \"sado-maso a transeúntes\" o Enrique López (Alias Quiller), señalado por negarse a escribir su nombre con 'K' porque \"eso era punky\", completando así el staff de RADICAL."
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Editorial"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Editorial del número 1"
  } ]
