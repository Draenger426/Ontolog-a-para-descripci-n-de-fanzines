}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#azagra",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_azagra"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Dibujo original y autógrafo del reconocido historietista Carlos Azagra, enviado desde Santa Coloma de Gramanet (Barcelona) como correspondencia para la redacción. La ilustración muestra a un personaje caricaturesco (estilo característico de su obra, similar a los del grupo P.G.B.) gritando con entusiasmo \"ESE FANCHINEE !!\" mientras señala un sobre cerrado, incluyendo debajo la firma del autor y su dirección postal en el Apartado 21 (código postal 08921)."
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Dibujos"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Azagra"
  } ]
