}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0423",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0457"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Artículo de opinión que carga contra el intervencionismo de EEUU (\"metepatas a lo cowboy\") pero critica con igual dureza la hipocresía de quienes defienden regímenes como Nicaragua y Cuba, argumentando que la falta de libertad y el partido único las convierten en dictaduras tan condenables como cualquier otra, cerrando con el refrán \"las cosas claras y el chocolate espeso\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Política"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0423"
  } ],
