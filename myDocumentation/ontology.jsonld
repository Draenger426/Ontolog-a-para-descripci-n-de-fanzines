}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#postal_navidad",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_postal01"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_postal02"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_postal03"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Postal de felicitación navideña de 1989, ilustrada por AJTG, que parodia el reparto del fanzine. La imagen principal muestra a un Papá Noel enloquecido pilotando un \"TURBO TRINEO GLX OPEL\" desbordado de revistas \"RADICAL AL KILO\" que salen volando por los aires. El interior incluye un mensaje de \"Felices Fiestas\" en tipografía gótica dentro de un bocadillo explosivo, y el reverso firma irónicamente como \"RADICAL AL KILO S.A.\" (Sociedad Anónima), fechando el documento en 1989."
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Postal"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Postal de Navidad"
  } ]
