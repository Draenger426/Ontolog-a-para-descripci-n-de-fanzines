}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0104",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0110"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Exclusiva con el bíblico Noé, encontrado de juerga en un chiringuito, quien confiesa que el Diluvio Universal fue un invento y que construyó el Arca únicamente para \"irse de marcha\" con los colegas por Marbella y la calle Pedro Antonio. El patriarca se muestra decepcionado con el ecologismo (preguntando si es \"alguna droga\") y se queja de la borrachera de los animales a bordo, todo ello maquetado con una estética de fanzine punk con letras recortadas tipo anónimo bajo el sello \"AHÍ QUEDA ESO\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Parodia"
  }, {
    "@value" : "Religión"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#a_saavedra"
