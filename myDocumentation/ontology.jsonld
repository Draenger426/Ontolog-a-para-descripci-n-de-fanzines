  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta sobre Oscar, un joven que quiere ligar y decide comprarse un coche. Tras ser rechazado con su Simca 1000, visita concesionarios de lujo (Ramborghini, Ferrari Tetarosa). Al final compra el coche de su abuelo (\"Kacho Karro\") y liga con una chica que resulta ser una reina africana, parodiando la película El Príncipe de Zamunda."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Humor"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
