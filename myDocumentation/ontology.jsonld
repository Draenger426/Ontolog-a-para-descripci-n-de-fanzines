}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0125",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0140"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Recopilación de chistes protagonizados por niños impertinentes (\"Los mentirosillos\", \"Los sinceros\", \"Los precoces\") que ponen en apuros a sus padres con insultos mal pronunciados (\"pulpo y sorra\") o preguntas escatológicas."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Humor verde"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0125"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Cómic"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Una de angelitos"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"
  } ],
