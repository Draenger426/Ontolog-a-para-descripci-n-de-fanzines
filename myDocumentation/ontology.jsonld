  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0108"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historia que narra en primera persona un viaje al Rally Safari en Nairobi (Kenia). El protagonista describe con humor sus desventuras al recibir un inadecuado Cadillac descapotable rosa de los años 60 en lugar de un todoterreno, vehículo con el que seduce a una misteriosa motorista en la sabana; la historia concluye con un salto temporal pesimista, donde el autor lamenta su aburrida vida doméstica actual (\"casado, con un niño y un abominable vehículo familiar\") frente a la libertad perdida de aquella aventura."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Humor negro"
  }, {
    "@value" : "Relatos"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#j_rodriguez"
  } ],
