}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0603",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0607"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0608"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0609"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Texto literario de tono bohemio que reivindica el \"hábito de la bebida\" frente a la vida sana y aburrida (\"gimnasta virtuoso\", \"cerveza sin alcohol\"). Cita a Baudelaire (\"Embriagaos\"), Poe, Hemingway y mitos griegos para defender una \"sabia administración\" de los venenos y pasiones. Incluye un anuncio de \"Bodegas Bedel\" con el eslogan \"Cava tu propia tumba\"."
  } ],
