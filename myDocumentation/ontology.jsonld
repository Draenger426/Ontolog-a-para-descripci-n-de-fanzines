    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0472"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Incluye una sopa de letras deportiva (cuya solución revela un mensaje insultante al lector), un crucigrama con definiciones absurdas y referencias locales al \"camarero del bar de la Facultad\", y una serie de jeroglíficos visuales basados en juegos de palabras fonéticos como \"Chocolate\" (Chocó-la-T) o el propio nombre del fanzine, \"Radical al Kilo\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Pasatiempos"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
