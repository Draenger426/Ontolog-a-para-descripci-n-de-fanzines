  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Facultad"
  }, {
    "@value" : "Juego de simulación del bar de la facultad de ciencias, pensado para 4-8 jugadores. El objetivo es cumplir las misiones que vienen en el índice. El que haga antes estas misiones gana el juego. Viene acompañado de un tablero que simula el mismo bar."
  }, {
    "@value" : "Pasatiempos"
  } ],
