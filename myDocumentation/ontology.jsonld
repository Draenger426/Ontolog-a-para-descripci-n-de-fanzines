  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0224",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0236"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Pasatiempos dedicada íntegramente a un autodefinido gigante, dibujado y rotulado a mano sobre una retícula. El crucigrama está firmado en la esquina inferior derecha por \"Botánico\" (o un alias similar) y fechado en el 87. Las definiciones combinan conocimientos de cultura general (\"Dios griego\", \"Río alemán\", \"Televisión alemana\") con referencias locales y al contexto universitario, destacando la casilla inicial \"Novatadas no gracias\" (reforzando la postura editorial contra ellas) o la pista \"Pueblo de GR\" (Granada). Incluye instrucciones básicas al pie: \"Una letra en cada casilla\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Pasatiempos"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0224"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Juegos"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num02"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Contenido #0224"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0225",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0237"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "La obra presenta una narrativa visual continua sin separación clásica de viñetas, donde una línea de trazo grueso actúa como \"camino\" que guía el ojo del lector a través de un paisaje alienígena. La secuencia ilustra el recorrido de una expedición: desde la llegada de la nave y el encuentro con fauna extraterrestre (seres con antenas y formas extrañas) hasta el descubrimiento de géiseres y fuentes hídricas, culminando con un robot explorador junto a un faro espacial."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Ciencia ficción"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0225"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Cómic"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "El explorador espacian nº3.2.111.X.Y.2: Misión agua"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num02"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_dibujante" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#j_a_lopez"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_guionista" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#j_a_lopez"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Contenido #0225"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0226",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0238"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Texto que yuxtapone pensamientos sobre la naturaleza del conocimiento y la creación, contrastando el arte con la ciencia (citando a Max Delbrück, Claude Bernard y Pablo Serrano), con sentencias mordaces sobre la condición humana y la ecología (el Jefe indio Seattle profetizando que \"una noche aparecerán ahogados en sus propios residuos\" o J. Thurber sobre la tala de árboles). También incluye críticas agudas a la institución universitaria (\"saca a la luz todas las capacidades, incluso la incapacidad\" de Chéjov) y definiciones ingeniosas sobre el amor y el matrimonio (Alejandro Dumas) o la neuroplasticidad (Ramón y Cajal)."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Literatura"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0226"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Citas"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num02"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Contenido #0226"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0227",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0239"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta donde un reportero entrevista a un primer plano monstruoso preguntándole por la causa de su aspecto; la criatura responde con un literal y seco \"SÍ\" antes de huir corriendo bajo la luna, provocando el comentario cínico del periodista: \"Je, je, conciso el nene\". La mitad inferior contiene un artículo titulado \"Boxeador de Primera...\", planteado como un \"Curso de Boxeo a Distancia\" absurdo. El texto enumera requisitos delirantes como \"tener la nariz rota (procédase)\" o poseer \"un cuenco por cabeza\". El entrenamiento sugerido incluye la \"táctica sorpresa\" (golpearse a uno mismo para confundir al rival haciéndole creer que es una trampa) y ejercicios de calentamiento consistentes en andar en círculos en una habitación pequeña y darse cabezazos contra la pared."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Ciencia ficción"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0227"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Cómic"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Preguntasss"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num02"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_dibujante" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#a_vargas"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_guionista" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#a_vargas"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
