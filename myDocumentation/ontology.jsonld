  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Diagrama técnico que explica el funcionamiento de un inodoro usando terminología informática. La taza es la \"Central Processing Unit\", la cisterna el \"Main Storage\", la escobilla son \"Debugging Tools\" y el papel higiénico \"Supplementary Data\". Incluye un ratón real (\"Mouse\") corriendo por el borde."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Humor"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
