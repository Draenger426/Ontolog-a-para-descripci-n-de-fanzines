  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0117",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0131"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0132"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Crítica a la tendencia política de financiar prioritariamente el desarrollo tecnológico (resultados mercantiles a corto plazo) en detrimento de la ciencia básica. El texto argumenta que grandes avances como los microchips, la ingeniería genética o las vacunas surgieron de estudios fundamentales sin utilidad inmediata prevista, advirtiendo que \"renunciar a la investigación básica supone renunciar a la aparición de otras nuevas tecnologías\" en el futuro."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Crítitcas"
  }, {
    "@value" : "Investigación"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#ece"
  } ],
