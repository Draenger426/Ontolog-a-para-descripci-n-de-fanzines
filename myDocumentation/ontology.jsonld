}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0402",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0409"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0410"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "El artículo analiza en profundidad la famosa placa dorada enviada al espacio en las sondas Pioneer 10 y 11 en 1972/73, diseñada por Carl Sagan y Frank Drake para contactar con posibles civilizaciones extraterrestres. La primera página explica el contexto histórico y el contenido codificado (el hombre y la mujer, la posición de la Tierra respecto a 14 púlsares y la transición del átomo de hidrógeno), mientras que la segunda página ofrece el diagrama completo de la placa con anotaciones técnicas detalladas sobre el funcionamiento de estos \"relojes galácticos\" y la esperanza de que el mensaje sea descifrado dentro de miles de millones de años."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Curiosidades"
  }, {
    "@value" : "Investigación científica"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pedro_gadicto"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0402"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Hola, bishos"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num04"
  } ],
