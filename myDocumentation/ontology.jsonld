  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0442"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta que narra la venganza de un Zeus enfadado por el olvido de los mortales tras 2000 años de vacaciones. El dios reúne a un panteón multicultural (con cameos telefónicos de deidades egipcias y nórdicas) para sembrar el caos en la Tierra: provocan accidentes de tráfico masivos entre risas y Neptuno juega literalmente a \"hundir la flota\" con barcos reales, cerrando la historia con una explosión nuclear de Ares y un cliffhanger que anticipa la llegada de Jesucristo y Alá."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Mitología girega"
  }, {
    "@value" : "Religión"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0416"
  } ],
