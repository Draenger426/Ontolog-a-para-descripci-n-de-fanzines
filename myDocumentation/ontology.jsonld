}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0126",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0141"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Pasatiempos de dos pruebas: una serie lógica de figuras geométricas (círculos, triángulos y cuadrados) que debe ser completada deduciendo el patrón, y un complejo laberinto rectangular donde el reto consiste en alcanzar el centro desde una de las cuatro entradas en menos de un minuto, ofreciendo las respuestas en un apartado lateral de \"SOLUCIÓN\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Pasatiempos"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#jorge_cassinello"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0126"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Juegos"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Pasatiempos"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Contenido #0126"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0127",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0142"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Compilación de series de titulares ficticios y gamberros que parodian la vida académica y departamental."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Facultad"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0127"
  } ],
