  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0464"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Ilustración que presenta a la mascota oficial de \"Radikal-al-Kilo (El Fanzine Cuántico)\", un personaje surrealista que sostiene una hélice y un objeto humeante bajo un gran número 5. El texto manuscrito bromea con la generosidad de los autores (\"Mirad que somos buenos\") regalando este diseño además del próximo número."
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0426"
