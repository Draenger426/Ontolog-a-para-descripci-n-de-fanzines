  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Pág 31 (Menú): \"Menú del día\" donde todos los platos son variaciones de arroz y huevo (\"Arroz a la cubana\", \"Arroz amarillento\", \"Huevos del Gran Duque\").\nPág 32 (Receta): \"Sopa de pecadillos\". Ingredientes: ropa interior del personal de secretaría, avecrem caducado y agua del retrete. Instrucciones para cocinarla (\"escupa dos veces\")"
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Facultad"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
