}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0119",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0135"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Documento satírico donde establece una lista de precios y multas para las parejas que sean sorprendidas en actitudes íntimas (\"manos en el muslo\", \"boca en aquello\") dentro de las instalaciones de la Facultad. Incluye una serie de adivinanzas con doble sentido para definir el miembro masculino (\"no piensa pero tiene cabeza\") y termina con un enorme sello de \"CENSURADO\" ocultando la definición de \"lo otro\", todo ello fechado en un imposible 31 de Junio de 1987."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Humor verde"
  }, {
    "@value" : "Parodia"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0119"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Bando y mandato"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"
  } ],
