  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0506"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0507"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Test de personalidad satírico para evaluar el nivel de compromiso estudiantil. Las preguntas (I a X) plantean dilemas sobre la asistencia a clase, la toma de apuntes (\"fotocopiar los de los demás\"), el comportamiento en la cafetería (mencionando \"El Jardines\") y la actitud ante los exámenes (copiar o soplar). Los resultados finales clasifican al lector en tres categorías: \"Espantoso empollón\" (Mayoría A, antisocial), \"Estudiante normal\" (Mayoría B) y \"Auténtico estudiante\" (Mayoría C, juerguista y con \"potra increíble\")."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Test"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#hugo"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0502"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Test"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num05"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
