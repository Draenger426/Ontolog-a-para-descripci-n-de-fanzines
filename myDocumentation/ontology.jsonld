    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#j_a_lopez"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
