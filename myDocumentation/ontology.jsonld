}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0115",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0128"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Descripción del caos mental de un estudiante a las 3 y 4 de la madrugada. Agobiado por prácticas sin pasar a limpio y trabajos pendientes, el protagonista intercala sus lamentos académicos con recuerdos de la lucha estudiantil (huelgas, asambleas y carreras delante de los \"grises\"), terminando su vigilia a las 5 a.m. con una mención irónica al ministro Maravall."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Estudiantes"
  }, {
    "@value" : "Universidad"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#gz"
