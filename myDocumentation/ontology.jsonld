}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0123",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0139"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Texto detallado sobre las sanciones económicas (en pesetas) impuestas por la captura o muerte de animales en peligro de extinción, valorando especies como la Foca Monge en 1.500.000 ptas o el Lince en un millón, y cierra con un listado de direcciones provinciales para denuncias o información."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Crítica política"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0123"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Especies protegidas - Fauna"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"
