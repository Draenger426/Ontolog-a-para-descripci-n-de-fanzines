}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0514",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0530"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Poema satírico que narra una epidemia de colitis masiva provocada por unos langostinos en mal estado consumidos por la Junta de Andalucía (referencia al caso real de la época). Describe con lenguaje escatológico los síntomas (\"truenos de zambombas\", \"pedorretas\") y el caos en Sevilla, donde el Guadalquivir sube de nivel por los vertidos fecales."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Poesía"
  }, {
    "@value" : "Política"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
