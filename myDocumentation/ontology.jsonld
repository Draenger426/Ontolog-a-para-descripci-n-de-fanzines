    "@value" : "Contenido #0221"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0222",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0233"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0234"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta que presenta un escenario urbano colapsado por \"sucesos\" (suicidios, asesinatos), con una multitud agolpada frente al \"Café El Legumbre\" y una ambulancia, ofreciendo irónicamente un número de teléfono para aquellos que se \"arrepientan a mitad de su suicidio\". La continuación muestra la habitación vacía del protagonista (con equipo de música y cama desecha), donde un \"Corresponsal Nº 01\" informa que el héroe, apodado \"El Percha\" desde 1842, está \"indispuesto\", cancelando la aventura con un \"otra ocasión será\". El conjunto se remata con un texto filosófico al pie firmado por \"El Cid Campeador\", quien lamenta su destino de caballero andante y desea haber sido un \"simple, vulgar y repugnante campesino\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Cómics"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0222"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Cómic"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Las aventuras de un superhéroe"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num02"
  } ],
