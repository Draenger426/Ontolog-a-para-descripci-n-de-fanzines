  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "El dibujo que aparece es un alumno recién graduado en la ruina, mientras pone 'I love precios públicos'"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Marcapáginas"
  } ],
