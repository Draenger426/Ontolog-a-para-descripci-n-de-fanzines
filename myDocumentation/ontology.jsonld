  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta donde un personaje de espaldas reflexiona hasta llegar a la conclusión de que la televisión es \"su peor enemigo\" y decide destrozar la pantalla de un puñetazo al grito de \"¡MALDITA MANIPULACIÓN!\"."
  } ],
