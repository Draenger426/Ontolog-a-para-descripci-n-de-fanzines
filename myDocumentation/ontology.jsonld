}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0106",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0114"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0115"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta que explora con ironía la amistad entre dos arquetipos juveniles supuestamente opuestos: Pepe (un heavy seguidor de W.A.S.P. y del Real Madrid) y Jose (un punky fan del Barça). A través de viñetas comparativas sobre sus gustos en mujeres (morenas vs rubias) y comida (lentejas con o sin chorizo), el autor concluye mostrando que, pese a sus diferencias superficiales, son esencialmente iguales y terminan abrazados."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Punk"
  }, {
    "@value" : "Tribus urbanas"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
