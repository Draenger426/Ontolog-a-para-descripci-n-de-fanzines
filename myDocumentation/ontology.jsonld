}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#reyes_vagos",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_cartareyes"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Flyer satírico navideño de 1991 titulado \"Queridos Reyes Vagos\", diseñado a modo de plantilla epistolar para que los lectores participen en un concurso de cartas. El texto invita a pedir regalos a una versión denigrante de los Reyes Magos, rebautizados como Melchor-izo, Gaspar-turiento y Baltasar-noso (que \"se han apuntado a Radical Al Kilo\"), ofreciendo como premio el sorteo de 2 botellas de cava entre las peticiones más originales. La composición visual es un collage de grabados antiguos de querubines y muñecos (firmados como \"Los muñequitos de POTOSA\") que lanzan frases sugerentes como \"¡Hazme tuyo!\", todo ello bajo el deseo desganado de una \"Feliz Navidad y tó éso\"."
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Dibujo"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Carta de Reyes Vagos"
  } ]
