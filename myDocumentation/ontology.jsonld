}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0430",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0473"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta que narra la frustración matutina de una pareja que se levanta motivada para llegar pronto a clase, pero su plan fracasa estrepitosamente cuando el autobús de la línea 28 pasa de largo sin detenerse, condenándolos a llegar \"otra vez tarde\" a las 7:30."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Estudiantes"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0430"
  } ],
