  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0121",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0137"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Texto paródico de consejos de revistas juveniles con un tono transgresor que normaliza el uso de doxidrinas, coca y éxtasis (traído de Ámsterdam), recomienda clínicas de aborto en Londres para decir \"adiós bultos\" y cierra con un manifiesto político ficticio de la candidata \"CUKITA\", quien bajo el lema \"LA UNICA ALTERNATIVA VICIOSSA\" promete \"sexo para todos\" y un \"orgasmo continuo\" si es elegida para Europa."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Cultura punk"
  }, {
    "@value" : "Humor verde"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0121"
  } ],
