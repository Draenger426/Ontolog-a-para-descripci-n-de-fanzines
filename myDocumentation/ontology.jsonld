  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Sección literaria que reúne algunos poeamos del autor Anselmo. Viene incluido:\n-Incomprensible soledad.\n-Comienza la aventura.\n-Paranoias sobresentimentales."
  }, {
    "@value" : "Texto con ilustraciones"
  } ],
