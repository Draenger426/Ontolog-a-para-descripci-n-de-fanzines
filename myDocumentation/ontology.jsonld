  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0632",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0689"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0690"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0691"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Cuarta parte de la historia de Pedro y Laura. El grupo entra en la \"Cueva de la Gitana\". En la oscuridad, Laura plantea el \"Enigma de las cerezas\" (el niño que no tenía cerezas, subió al cerezo que no tenía cerezas...). Pedro lo resuelve (jugando con el plural y singular). Salen de la cueva y planean una barbacoa."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
