}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0418",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0444"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Página que parodia la exploración espacial mediante las supuestas fotografías enviadas por la sonda \"Voyeur\" (juego de palabras con la Voyager). El texto relata la conmoción científica causada por las imágenes de tres alienígenas de aspecto grotesco y cómico, concluyendo que, tras un análisis del Departamento de Biología de la Universidad de Granada, se confirma la existencia de vida pero se dictamina que las posibilidades de que sea inteligente son \"prácticamente nulas\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Ciencia ficción"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0418"
  } ],
