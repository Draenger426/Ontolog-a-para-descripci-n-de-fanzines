}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#calendario04",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_calendario0401"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_calendario0402"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Calendario de bolsillo de 1997 publicitario del \"Café Bar LAS TORRES\", un establecimiento clásico situado en la calle Trucha del barrio de La Chana (Granada), regentado por José Puertas Díaz y famoso por sus \"tapas variadas y caracoles\". El lote se completa con una tarjeta satírica sobre gestión laboral (\"Escoja usted\"), que ilustra el clásico \"triángulo de la calidad\" obligando al cliente a elegir solo dos opciones entre un trabajo \"Barato, Rápido y Bueno\", advirtiendo que la combinación de las tres es imposible."
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Calendario"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Calendario #04"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#certamen_humor",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img_certamen"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Cartel informativo del \"I CERTAMEN DE HUMOR SAN ALBERTO MAGNO\", un concurso organizado por la Asociación Cultural Radical Al Kilo que abarca categorías de redacción, fotografía y humor gráfico. La ilustración central muestra a un personaje ambicioso gritando \"¡LO QUIERO TODOO!\" desde un despacho caótico lleno de humo y objetos extraños (incluyendo un pollo colgado), mientras un operario termina de pegar el cartel en una valla publicitaria. El evento cuenta con el patrocinio institucional del Vicerrectorado de Estudiantes y la colaboración de la Casa de Porras y la Facultad de Ciencias, dirigiendo a los interesados a la Sala de Alumnos o al apartado de correos 1275 de Granada."
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto con dibujo"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "I CERTAMEN DE HUMOR SAN ALBERTO MAGNO"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num12"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Material_promocional"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "I Certamen de Humor"
  } ]
