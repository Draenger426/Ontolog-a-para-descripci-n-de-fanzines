  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#descripcion_revista" : [ {
    "@value" : "Fanzine creado por los alumnos de la Facultad de Ciencias de la Universidad de Granada entre los 80 y 90. Se compone de 13 números y varios suplementos que iban junto a estos (ya sean periódicos u otra revista alternativa llamada Radikal Stylo)."
  } ],
  "http://example.org/ontologia#tiene_periodicidad" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#periodicidad_revista"
  } ],
