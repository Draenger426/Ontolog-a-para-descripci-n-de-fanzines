  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Parodia macabra de un catálogo de juguetes (muñecas \"Famosa\"). Presenta muñecos como \"Sifilín\" (con sífilis), \"Leprin\" (leproso), \"Baby Ladillas\", \"Pustulín\", \"Pajín Solito\" o \"Barriguitas Negro\" (para jugar al Apartheid). Incluye una \"Nueva Aventura\" narrada con estos personajes."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Humor negro"
  }, {
    "@value" : "Parodias"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#ignacio_nalista"
  } ],
