    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0110"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "La enseñanza"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Contenido #0110"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0111",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0121"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Parodia sobre la ansiedad de los exámenes mediante un collage visual donde un profesor exige la entrega de las hojas tras dos horas de tiempo, mientras el alumno intenta responder a la \"Pregunta 1ª: Concepto de Cretino\" en un absurdo \"2º Parcial de Cretino\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Exámanes"
  }, {
    "@value" : "Parodias"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0111"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Cómic"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "No estudiaste bastante"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"
  } ],
