  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0432"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta donde un estudiante se dispara en la sien tras estudiar para un examen, mientras su compañero se preocupa únicamente de que no le salpique sangre. En la mitad inferior, un anuncio satírico del \"BANCO JONES\" invita a donar esperma bajo la dirección de los doctores con nombres de doble sentido \"Tomas Turbado\" y \"Pepa Jotera\", ubicados en la Calle Chorrillo nº 69."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Estudiantes"
  }, {
    "@value" : "Humor negro"
  } ],
