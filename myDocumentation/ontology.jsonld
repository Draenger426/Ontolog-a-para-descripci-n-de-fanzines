}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0408",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0421"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0422"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Reseña de la película \"Jungla de Cristal\" (Die Hard), donde se analiza el reparto liderado por Bruce Willis y Bonnie Bedelia, la dirección de John McTiernan y la trama en el Nakatomi Plaza, incluyendo un reto manuscrito que ofrece un fanzine gratis a quien encuentre un error en el texto. Cierra con la sección \"Consejos Al-Kilo\", ilustrando una campaña de concienciación sobre el uso del preservativo en relaciones homosexuales y heterosexuales."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Cine"
  }, {
    "@value" : "Críticas"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pedro_gadicto"
  } ],
