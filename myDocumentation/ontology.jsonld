  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0120",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0136"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Se expone en tres actos la alienación de un personaje que odia el popular concurso \"Un, Dos, Tres\", sufre las burlas de sus amigos por sus poemas simplistas y se ve relegado a esperar en la escalera mientras limpian el suelo, concluyendo con una pregunta desesperada sobre el sentido de la vida mientras sostiene un revólver."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Crítica social"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0120"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Cómic"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Problemas de un inadaptado"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_dibujante" : [ {
