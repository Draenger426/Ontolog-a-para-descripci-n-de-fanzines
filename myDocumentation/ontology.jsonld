  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0423"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0424"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta donde la infiltración de un sujeto en una vivienda nocturna, revelándose en el desenlace que el protagonista es en realidad una mosca que muere abatida al entrar en contacto con una nube tóxica de insecticida RAID."
