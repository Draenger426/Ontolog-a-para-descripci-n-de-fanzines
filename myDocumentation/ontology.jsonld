    "@id" : "http://example.org/ontologia#Contenido"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Contenido #0109"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0110",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0120"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Se cuestiona el rol de la universidad como teórica \"fuente del saber\". El texto lamenta que, en lugar de fomentar la curiosidad natural del Homo sapiens, el sistema se haya convertido en una absurda \"competición para ver quién traga más\", donde el único objetivo es memorizar y \"REPETIR lo que anteriormente ha copiado\", vaciando de sentido el proceso de aprendizaje."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Crítica social"
  }, {
    "@value" : "Facultad"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#jorge_cassinello"
  } ],
