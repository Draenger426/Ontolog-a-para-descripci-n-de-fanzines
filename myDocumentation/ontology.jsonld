}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0415",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0433"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0434"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Tesina paródica sobre los \"NÚMEROS RODRIGUEZ\" desarrollada por la ficticia \"sucursal de Harvard en Granada\" mediante becas destinadas a litronas, definiendo este conjunto matemático como inútil, \"amorfo consigo mismo\" y publicado originalmente en papel higiénico. La exposición gráfica de la teoría incluye teoremas representados mediante un corte de mangas 3D (definido como \"Punto Maximal\"), un excremento humeante (\"Primura de Ideal\") y juegos de palabras como el \"Teorema de Vicente Orema\" o definiciones circulares sobre \"hacer el primo\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Matemáticas"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0415"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Reseña sobre los números Rodríguez"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num04"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
