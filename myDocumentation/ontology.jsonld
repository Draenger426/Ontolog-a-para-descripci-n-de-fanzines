  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0420"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta donde un suicida se lanza al mar con un peso de 100 kg atado al pie, pero sobrevive porque el agua desaparece instantáneamente al zambullirse, dejándolo perplejo en el fondo seco junto a peces y barcos varados."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Humor negro"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
