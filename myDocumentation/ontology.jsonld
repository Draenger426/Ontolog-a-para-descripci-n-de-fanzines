  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0133"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0134"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta que propone una serie de estiramientos gimnásticos ilustrados mediante figuras humanas estilizadas y abstractas bajo la firma de Lop. La rutina viene acompañada de la instrucción específica de realizarse escuchando el \"Concerti Grossi Op. 3\" de Haendel e incluye una misteriosa pancarta con la inscripción \"S.T. 1942 ORDER UNIVERSITI\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Humor negro"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0118"
  } ],
