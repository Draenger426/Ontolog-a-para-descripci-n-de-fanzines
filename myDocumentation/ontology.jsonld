  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Cuestionario humorístico de 15 preguntas para medir el nivel de obsesión sexual del lector (\"¿Qué es un agujero negro?\", \"¿Qué te llevarías a una isla desierta?\"). Las opciones de respuesta van desde lo ingenuo hasta lo obsceno. Los resultados clasifican al lector entre \"Tonto/Estrecho\", \"Condenado al sufrimiento\", \"Maricón\" (sic) o \"Auténtico SALIDO de mierda\". Cierra con un anuncio de cursos de Sado-Masoquismo de la Academia PYG."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Cuestionario"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
