}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0406",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0417"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0418"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0419"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "La trama sigue a la protagonista, una justiciera que golpea a \"choris\" en callejones, hasta que se encuentra con Superman en el \"Super's Pub\" y lo invita a su apartamento. El clímax cómico llega cuando ella aparece en lencería insinuando un encuentro sexual (un \"superpolvo\"), momento en el que Superman huye despavorido inventándose una emergencia auditiva, dejando su traje atrás y provocando las burlas de las otras heroínas que por fin descubren \"dónde guarda su ropa\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Parodias"
  }, {
    "@value" : "Superhéroes"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0406"
  } ],
