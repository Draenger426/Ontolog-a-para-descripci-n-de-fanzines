}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0108",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0118"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Relato que transporta al lector al siglo XXIII en una Granada post-nuclear habitada por mutantes y androides. El texto describe un sistema educativo brutal donde los alumnos se enfrentan a la \"desintegración molecular\" si suspenden y donde materias como la Genética o la \"Matemática Astral\" han sustituido a la Física, concluyendo con pesimismo que, al igual que en el siglo XX, la única salida para el estudiante ante la falta de compañerismo es \"LA RESIGNACION\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Ciencia ficción"
  }, {
    "@value" : "Críticas"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#antonio_cadenas"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0108"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Un día después"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Contenido #0108"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0109",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0119"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta que relata la jornada de ocio de un trabajador radiactivo tras salir de la factoría. El protagonista, dotado de \"movimiento continuo\" por su mutación, visita el \"Parque del Prisma Plexigláctico\" para admirar los nuevos hologramas y concierta una cita en clave (traducida al \"dialecto humano\") para una asamblea en la cooperativa."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Ciencia ficción"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0109"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Cómic"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "El Mutante: Un día"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num01"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_dibujante" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#antonio_cadenas"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_guionista" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#angel_martinez"
  } ],
