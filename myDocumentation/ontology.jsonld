}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0602",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0605"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0606"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Artículo divulgativo-satírico sobre la historia del preservativo, desde los egipcios y Gabriel Fallopio hasta el Doctor Condom (médico de Carlos II de Inglaterra). Explica su evolución de tripa de animal a látex vulcanizado. Incluye falsos anuncios de condones \"Descontrol\" (\"Virginidad es igual a cáncer\") y viñetas humorísticas."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Historia"
  }, {
    "@value" : "Humor verde"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pedro_gadicto"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0602"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Condón"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num06"
