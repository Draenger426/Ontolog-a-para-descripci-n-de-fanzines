    "@value" : "Contenido #0213"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0214",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0222"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Artículo dedicado al grupo barcelonés de rock urbano Amaro, destacando su álbum debut \"Mordiendo la vida\" (producido por Lorenzo Santamaría). Se detalla la formación de la banda: la \"voz con garra\" de Joana Amaro, la guitarra de Robert \"Marmolillo\" y la batería de Celes Baldís (ex miembro de Akarokeda). El texto lamenta la cancelación de su concierto previsto en Granada y cierra recomendando verlos en directo \"si tenéis ocasión\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Música"
  }, {
    "@value" : "Rock"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#antonio_cadenas"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0214"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
