    "@value" : "RAK"
  } ],
  "http://example.org/ontologia#titulo_revista" : [ {
    "@value" : "Radikal Al Kilo"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#descontinuada" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ],
