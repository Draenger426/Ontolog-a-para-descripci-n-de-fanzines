}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0216",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0224"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0225"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0226"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Artículo que aborda con rigor académico y un tono desenfadado el origen de la vida, planteando el código genético como un \"enigma irresoluble\" o un \"accidente congelado\" frente a las teorías del diseño inteligente (el \"superingeniero de obras perfectas\"). A lo largo de las páginas se utilizan metáforas criptográficas (ilustradas con un Sherlock Holmes analizando secuencias de nucleótidos) y ejemplos lingüísticos como la frase \"HACEGRANRATOCOMIBIENPEROPOCO\" para explicar la lectura de tripletes sin puntuación. El artículo incluye viñetas humorísticas, como el diálogo entre la Alanina y el triplete GCA, y concluye definiendo la evolución como una \"gran chapucera\" (citando a Jacob), cerrando con un juego de palabras que sustituye a Adán y Eva por \"ADN y EVOS\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Biología"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#juan_antonio_fiol"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0216"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Ciencia en acción: ¿Cómo nació el código genético?"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num02"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Contenido #0216"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0217",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0227"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Ilustración a página completa de estilo realista que simula una fotografía de grupo en un campamento de expedición. La imagen muestra a una decena de jóvenes (presumiblemente estudiantes) posando frente a tiendas de campaña tipo canadiense y un paisaje montañoso árido. El texto acompaña la escena con un tono de falso documental o inside joke: \"15 DE MAYO. Primer aniversario de la desaparición de un grupo de biólogos del 3er. curso en Cun-al-Sar (Yemen). Pocas explicaciones y mucho silencio\", sugiriendo un misterio ficticio sobre el destino de los alumnos durante una salida de campo."
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0217"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Ilustración"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num02"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Contenido #0217"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0218",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0228"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Texto que se centra monográficamente en el sello discográfico Windham Hill Records (traducido poéticamente como \"La colina de los artesanos\"), destacando su estética visual cuidada y la calidad de sus grabaciones. Se repasa la trayectoria de su fundador, el guitarrista William Ackerman, y se listan artistas clave del catálogo como George Winston (con sus álbumes estacionales), Michael Hedges (\"Aerial Boundaries\"), Shadowfax, Alex de Grassi o Mark Isham, entre otros. Incluye una ilustración alegórica de una colina con un disco amaneciendo y la portada del álbum \"Past Light\" de Ackerman."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Música"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#Ravegugi"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0218"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto con ilustraciones"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "La nueva era con la \"Colina de los Artesanos\""
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num02"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Contenido #0218"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0219",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0229"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0230"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historia que narra la tragedia de Eddie Ruf, hijo pacifista y religioso del capo mafioso Jonathan Ruf, quien intenta vivir honradamente con una tienda de comestibles al margen de los negocios sucios de su padre. Tras sufrir el acoso brutal del rival Frank Sagrave (saqueos, secuestros y el asesinato de su hija Katherine), Eddie decide romper sus principios y tomarse la justicia por su mano. El desenlace es un anticlímax de humor negro: justo antes de cometer el crimen, Eddie muere accidentalmente atragantado con un pedazo de carne debido a los nervios. La maquetación utiliza líneas geométricas conectando bloques de texto con imágenes prediseñadas de revólveres y bombas. El relato cierra con un falso anuncio del \"Consejo Europeo de Seguridad Ciudadana\" que vende \"planes personalizados de defensa\" bajo el eslogan: \"Llévese un guardaespaldas puesto\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Relatos"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#j_rodriguez"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0219"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Chicago años 20"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num02"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Contenido #0219"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0220",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0231"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta que retrata con humor la realidad de las largas noches de hincar codos. La escena comienza con un bodegón clásico de estudiante: flexo encendido, café caliente y apuntes, bajo la resignada premisa de \"otro curso más, ahora a apencar\". El protagonista revisa su material de Genética y Micro (Microbiología), pero al llegar a los supuestos apuntes de Zoología (carpeta de Vertebrados), descubre que el contenido real es una revista Playboy camuflada, revelando la verdadera naturaleza de su \"estudio\" nocturno."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Estudiantes"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0220"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Cómic"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Es de noche... la hora del ESTUDIO"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num02"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_dibujante" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#jorge_cassinello"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#tiene_guionista" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#jorge_cassinello"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Contenido #0220"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0221",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0232"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Crónica musical que define a Bono y compañía como \"chicos educados, concienciados políticamente y muy religiosos\", contraponiendo su actitud a los excesos de \"sexo, drogas y rock'n'roll\" de grupos como Rolling Stones, Led Zeppelin o The Who (a quienes acusa de montar orgías y destrozar hoteles). El artículo destaca su reciente concierto multitudinario en el Santiago Bernabéu (7 de julio) ante más de 100.000 personas, donde interpretaron el tema \"Spanish Eyes\", y cierra con una anécdota sobre la estricta moral católica de Bono durante las giras."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Música"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pedro_gadicto"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0221"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Texto"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "U2: El grupo radiactivo"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num02"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://example.org/ontologia#Contenido"
  } ],
