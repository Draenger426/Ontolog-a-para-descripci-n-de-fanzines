  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0416"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Anuncio satírico a página completa que promueve el uso de anticonceptivos durante las fiestas con el eslogan \"¡SEA NAVIDEÑO! USE PRESERVATIVOS EL POLVORÓN\". La ilustración presenta a un Papá Noel risueño que sostiene una caja de estos profilácticos, descritos como \"LOS MÁS SOLICITADOS EN ESTAS FECHAS\", jugando con el doble sentido entre el dulce típico navideño y la jerga sexual (\"echar un polvo\")."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Humor verde"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0405"
  } ],
