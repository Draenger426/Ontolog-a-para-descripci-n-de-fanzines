}, {
  "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#con0422",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0453"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0454"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0455"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0456"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Historieta que relata con cinismo la evolución académica desde la Prehistoria y Egipto (con chistes sobre geometría proyectiva y esclavitud) hasta la época romana, donde se sustituyen los teoremas por alcohol y el estudio por sexo bajo la advocación de \"Viva Bolzano\". La narrativa avanza hacia la vida estudiantil moderna mezclando violencia política (con una referencia explícita a ETA provocada por un suspenso en Álgebra), críticas al profesorado (representados como burros) y aburrimiento en clase, para culminar con la solución final a todos los problemas: la fiesta universitaria en la famosa zona de bares de Granada, \"Pedro Antonio's Street\"."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Historia"
  }, {
    "@value" : "Matemáticas"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0422"
  } ],
  "http://example.org/ontologia#tipo_contenido" : [ {
    "@value" : "Cómic"
  } ],
  "http://example.org/ontologia#titulo_contenido" : [ {
    "@value" : "Historia de las matemáticas"
  } ],
  "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#esta_incluido_en" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#num04"
  } ],
