  "http://example.org/ontologia#aparece_en_imagen" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0116"
  }, {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#img0117"
  } ],
  "http://example.org/ontologia#descripcion" : [ {
    "@value" : "Artículo de crítica que denuncia el \"ambiente aséptico\" y los \"dictados sin fin\" de la facultad, relatando una acción reivindicativa real en la que se pegó un artículo de Juan Delval (publicado en El País) en la puerta del aula B-3 para exigir una enseñanza basada en \"hacer ciencia\" e investigar, en lugar de la mera transmisión pasiva de contenidos que practican los profesores."
  } ],
  "http://example.org/ontologia#palabra_clave" : [ {
    "@value" : "Críticas"
  }, {
    "@value" : "Facultad"
  } ],
  "http://example.org/ontologia#tiene_autor" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#a_vargas"
  } ],
  "http://example.org/ontologia#tiene_paginacion" : [ {
    "@id" : "http://www.semanticweb.org/usuario1/ontologies/2025/4/untitled-ontology-2#pag0107"
  } ],
